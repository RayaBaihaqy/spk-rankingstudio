      sessionStorage.setItem("spk_matrixX", JSON.stringify(matrixX));

      // Default weights
      const defaultWeights = {
        c1: 0.2,
        c2: 0.15,
        c3: 0.15,
        c4: 0.2,
        c5: 0.15,
