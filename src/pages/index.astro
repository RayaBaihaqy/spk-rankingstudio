---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import StepProgress from "../components/StepProgress.astro";
import HeroSection from "../components/HeroSection.astro";
import ColumnMappingModal from "../components/ColumnMappingModal.astro";
import StepBobot from "../components/StepBobot.astro";
import StepMatriks from "../components/StepMatriks.astro";
import StepHasil from "../components/StepHasil.astro";
// AHP Modules
import GenreStepUpload from "../components/genre/GenreStepUpload.astro";
import GenreStepPairwise from "../components/genre/GenreStepPairwise.astro";
import GenreStepHasil from "../components/genre/GenreStepHasil.astro";
import MangaStepUpload from "../components/manga/MangaStepUpload.astro";
import MangaStepPairwise from "../components/manga/MangaStepPairwise.astro";
import MangaStepHasil from "../components/manga/MangaStepHasil.astro";
---

<Layout>
  <!-- SheetJS CDN (must load before components use XLSX) -->
  <script
    src="https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js"
    is:inline
  ></script>

  <!-- Fixed Navbar -->
  <Navbar />

  <!-- Step Progress (hidden until Step 1 begins) -->
  <StepProgress />

  <!-- Hero / Upload Section -->
  <HeroSection />

  <!-- Column Mapping Modal (hidden, shown after upload) -->
  <ColumnMappingModal />

  <!-- Studio SAW Sections -->
  <StepBobot />
  <StepMatriks />
  <StepHasil />

  <!-- Genre AHP Sections -->
  <GenreStepUpload />
  <GenreStepPairwise />
  <GenreStepHasil />

  <!-- Manga AHP+SAW Sections -->
  <MangaStepUpload />
  <MangaStepPairwise />
  <MangaStepHasil />

  <!-- Main App Controller -->
  <script>
    // =============================================
    // SPK App Controller — Multi-Module Orchestration
    // =============================================

    let activeModule = 'selector'; // 'selector' | 'studio' | 'genre' | 'manga'
    let currentStep  = 0;
    let excelData    = null; // { headers, rows }

    // All section IDs across all modules
    const ALL_SECTION_IDS = [
      'hero-section',
      'step-bobot', 'step-matriks', 'step-hasil',
      'genre-step-upload', 'genre-step-pairwise', 'genre-step-hasil',
      'manga-step-upload', 'manga-step-pairwise', 'manga-step-hasil',
    ];

    function hideAll() {
      ALL_SECTION_IDS.forEach(id => {
        const el = document.getElementById(id);
        if (el) el.style.display = 'none';
      });
    }

    function showHeroSelector() {
      hideAll();
      const hero = document.getElementById('hero-section');
      if (hero) hero.style.display = 'flex';
      window.showModuleSelector?.();
      const prog = document.getElementById('step-progress-container');
      if (prog) prog.style.display = 'none';
      activeModule = 'selector';
      sessionStorage.removeItem('spk_activeModule');
    }

    function startModule(moduleId) {
      activeModule = moduleId;
      sessionStorage.setItem('spk_activeModule', moduleId);

      if (moduleId === 'studio') {
        hideAll();
        const hero = document.getElementById('hero-section');
        if (hero) hero.style.display = 'flex';
        window.showStudioUploadPanel?.();
        const prog = document.getElementById('step-progress-container');
        if (prog) prog.style.display = 'none';
        currentStep = 0;
      } else if (moduleId === 'genre') {
        showGenreStep(1);
      } else if (moduleId === 'manga') {
        showMangaStep(1);
      }
    }

    // =========================================
    // STUDIO FLOW (existing, preserved)
    // =========================================

    const STUDIO_SECTIONS = { 1: 'step-bobot', 2: 'step-matriks', 3: 'step-hasil' };

    function showStep(step) {
      if (step === 0) {
        if (activeModule === 'studio') {
          // Go back to studio upload within hero
          hideAll();
          const hero = document.getElementById('hero-section');
          if (hero) hero.style.display = 'flex';
          window.showStudioUploadPanel?.();
          const prog = document.getElementById('step-progress-container');
          if (prog) prog.style.display = 'none';
        } else {
          showHeroSelector();
        }
        return;
      }

      if (activeModule !== 'studio') {
        // Guard: only route Studio steps if module is studio
        return;
      }

      hideAll();
      const id = STUDIO_SECTIONS[step];
      if (id) {
        const el = document.getElementById(id);
        if (el) el.style.display = 'block';
      }
      currentStep = step;

      window.setProgressConfig?.('studio');
      window.updateStepProgress?.(step);
      setTimeout(() => window.scrollTo({ top: 0, behavior: 'smooth' }), 50);

      if (step === 1) window.initBobotStep?.();
      if (step === 2) window.initMatriksStep?.();
      if (step === 3) window.initHasilStep?.();
    }

    // =========================================
    // GENRE AHP FLOW
    // =========================================

    const GENRE_SECTIONS = { 1: 'genre-step-upload', 2: 'genre-step-pairwise', 3: 'genre-step-hasil' };

    function showGenreStep(step) {
      hideAll();
      const id = GENRE_SECTIONS[step];
      if (id) {
        const el = document.getElementById(id);
        if (el) el.style.display = 'block';
      }
      window.setProgressConfig?.('genre');
      window.updateStepProgress?.(step);
      setTimeout(() => window.scrollTo({ top: 0, behavior: 'smooth' }), 50);
      if (step === 2) window.initGenrePairwise?.();
      if (step === 3) window.initGenreHasil?.();
    }

    // =========================================
    // MANGA AHP+SAW FLOW
    // =========================================

    const MANGA_SECTIONS = { 1: 'manga-step-upload', 2: 'manga-step-pairwise', 3: 'manga-step-hasil' };

    function showMangaStep(step) {
      hideAll();
      const id = MANGA_SECTIONS[step];
      if (id) {
        const el = document.getElementById(id);
        if (el) el.style.display = 'block';
      }
      window.setProgressConfig?.('manga');
      window.updateStepProgress?.(step);
      setTimeout(() => window.scrollTo({ top: 0, behavior: 'smooth' }), 50);
      if (step === 2) window.initMangaPairwise?.();
      if (step === 3) window.initMangaHasil?.();
    }



