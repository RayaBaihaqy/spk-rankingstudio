      showStep(1);
    });

    // === FILE UPLOAD HANDLER ===
    window.addEventListener("spk:file-selected", async (e) => {
      const file = e.detail?.file;
      if (!file) return;

      // Wait for XLSX to be available
      let attempts = 0;
      while (typeof XLSX === "undefined" && attempts < 20) {
        await new Promise((r) => setTimeout(r, 100));
        attempts++;
      }

      if (typeof XLSX === "undefined") {
        window.showDropzoneState?.("idle");
        alert("Library Excel belum dimuat. Refresh halaman dan coba lagi.");
        return;
      }

      try {
        // Parse Excel
        const buffer = await file.arrayBuffer();
        const data = new Uint8Array(buffer);
        const workbook = XLSX.read(data, { type: "array" });
        const sheetName = workbook.SheetNames[0];
        const sheet = workbook.Sheets[sheetName];
        const jsonData = XLSX.utils.sheet_to_json(sheet, {
          header: 1,
          defval: "",
        });

        if (!jsonData || jsonData.length < 2) {
          window.showDropzoneState?.("idle");
          alert("File Excel kosong atau tidak valid.");
          return;
        }

        const headers = jsonData[0]
          .map((h) => String(h).trim())
          .filter((h) => h !== "");
        const rawRows = jsonData
          .slice(1)
          .filter((row) => row.some((cell) => cell !== "" && cell !== null));
        const rows = rawRows.map((row) => {
          const obj = {};
          headers.forEach(
            (h, i) => (obj[h] = row[i] !== undefined ? row[i] : "")
          );
          return obj;
        });

        excelData = { headers, rows, filename: file.name };

        window.showDropzoneState?.(
          "success",
          file.name,
          `${rows.length} baris data ditemukan`
        );
        window.openMappingModal?.(headers, rows, file.name);
      } catch (err) {
        window.showDropzoneState?.("idle");
        alert("Error membaca file: " + err.message);
      }
    });

    // === MAPPING CONFIRMED ===
    window.addEventListener("spk:mapping-confirmed", (e) => {
      const mapping = e.detail;
      if (!excelData) return;

      const { headers, rows } = excelData;
      const studios = [];
      const matrixX = [];

      rows.forEach((row) => {
        const studioName = String(row[mapping.studioCol] || "").trim();
        if (!studioName) return;
        studios.push(studioName);

        const criteriaKeys = ["c1", "c2", "c3", "c4", "c5", "c6"];
        const vals = criteriaKeys.map((key) => {
          const colName = mapping[key];
          const raw = row[colName];
          const parsed = parseFloat(String(raw).replace(/,/g, "."));
          return isNaN(parsed) ? 0 : parsed;
        });
        matrixX.push(vals);
      });

      if (studios.length === 0) {
        alert(
          "Tidak ada data studio yang bisa diambil. Periksa mapping kolom."
        );
        return;
      }

      sessionStorage.setItem("spk_studioNames", JSON.stringify(studios));
      sessionStorage.setItem("spk_matrixX", JSON.stringify(matrixX));
      sessionStorage.setItem("spk_colMapping", JSON.stringify(mapping));

      showStep(1);
    });

    // === MULTI-MODULE STEP NAVIGATION ===
    window.addEventListener("spk:start-module", (e) => {
      const moduleId = e.detail?.moduleId;
      if (moduleId) startModule(moduleId);
    });

    window.addEventListener("spk:back-to-hero", () => {
      showHeroSelector();
    });

    // Studio Navigation (from components)
    window.addEventListener("spk:goto-step", (e) => {
      const step = e.detail?.step;
      if (step !== undefined) showStep(step);
    });

    // Genre Navigation
    window.addEventListener("spk:genre-goto-step", (e) => {
      const step = e.detail?.step;
      if (step !== undefined) showGenreStep(step);
    });

    // Manga Navigation
    window.addEventListener("spk:manga-goto-step", (e) => {
      const step = e.detail?.step;
      if (step !== undefined) showMangaStep(step);
    });

    // Genre to Manga Bridge
    window.addEventListener("spk:genre-to-manga", () => {
      startModule('manga');
      // show genre winner banner
      if (typeof window.initMangaUploadFromGenre === 'function') {
        setTimeout(() => window.initMangaUploadFromGenre(), 100);
      }
    });

    // === INIT ===
    hideAll();
    const savedModule = sessionStorage.getItem('spk_activeModule');
    if (savedModule) {
      startModule(savedModule);
    } else {
      showHeroSelector();
    }
  </script>
</Layout>
