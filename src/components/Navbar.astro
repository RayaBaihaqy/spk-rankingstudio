---
// src/components/Navbar.astro
---

<nav id="main-navbar" class="fixed top-0 left-0 right-0 z-50" style="background: #e5e5e5; border-bottom: var(--border-thick); color: var(--text-primary);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo & Title -->
      <div class="flex items-center gap-3">
        <!-- Icon brutalist -->
        <div class="w-10 h-10 flex items-center justify-center bg-blue-600 text-white" style="border: var(--border-thin); box-shadow: 2px 2px 0px var(--ink); transform: rotate(-3deg);">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 relative z-10">
            <path d="M18.375 2.25c-1.035 0-1.875.84-1.875 1.875v15.75c0 1.035.84 1.875 1.875 1.875h.75c1.035 0 1.875-.84 1.875-1.875V4.125c0-1.036-.84-1.875-1.875-1.875h-.75zM9.75 8.625c0-1.036.84-1.875 1.875-1.875h.75c1.036 0 1.875.84 1.875 1.875v11.25c0 1.035-.84 1.875-1.875 1.875h-.75a1.875 1.875 0 01-1.875-1.875V8.625zM3 13.125c0-1.036.84-1.875 1.875-1.875h.75c1.036 0 1.875.84 1.875 1.875v6.75c0 1.035-.84 1.875-1.875 1.875h-.75A1.875 1.875 0 013 19.875v-6.75z" />
          </svg>
        </div>
        <div>
          <div class="font-black text-lg leading-tight tracking-wide text-slate-900 uppercase" style="font-family:'Rajdhani',sans-serif;">
            SPK <span class="bg-blue-600 text-white px-1">Studio</span>
          </div>
          <div class="text-[0.65rem] font-bold uppercase tracking-widest text-slate-500">Sistem Pendukung Keputusan</div>
        </div>
      </div>

      <!-- Reset button -->
      <button
        id="btn-reset-all"
        onclick="if(confirm('Reset semua data dan mulai dari awal?')){ sessionStorage.clear(); window.location.reload(); }"
        class="flex items-center gap-2 px-4 py-2 font-bold uppercase text-xs"
        style="background: var(--fire); color: white; border: var(--border-thick); box-shadow: 3px 3px 0px var(--ink); transition: all 0.1s;"
        onmouseover="this.style.transform='translate(-2px, -2px)'; this.style.boxShadow='5px 5px 0px var(--ink)';"
        onmouseout="this.style.transform='translate(0, 0)'; this.style.boxShadow='3px 3px 0px var(--ink)';"
        onmousedown="this.style.transform='translate(2px, 2px)'; this.style.boxShadow='1px 1px 0px var(--ink)';"
        title="Reset semua data"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
        <span class="hidden sm:inline">Reset</span>
      </button>
    </div>
  </div>
</nav>

<script>
  function updateNavProgress(step) {
    // kept for compatibility
  }
  window.updateNavProgress = updateNavProgress;
</script>
