---
// src/components/StepBobot.astro
---

<section id="step-bobot" class="pt-20 pb-12 bg-transparent" style="display:none;">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="mb-8 anim-slide-up">
      <div class="flex items-center gap-4 mb-2">
        <div class="w-12 h-12 bg-blue-600 text-white flex items-center justify-center border-[3px] border-slate-900 shadow-[4px_4px_0px_rgba(15,23,42,1)] transform -rotate-3">
          <span class="font-black text-2xl" style="font-family:'Rajdhani',sans-serif;">1</span>
        </div>
        <div>
          <h2 class="text-3xl font-black text-white uppercase tracking-wide" style="font-family:'Rajdhani',sans-serif;">Input Bobot Kriteria</h2>
          <p class="text-slate-600 font-bold bg-white inline-block px-2 py-0.5 border-2 border-slate-900 shadow-[2px_2px_0px_rgba(15,23,42,1)] mt-1">Total harus tepat <strong>1.0</strong></p>
        </div>
      </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-6">

      <!-- LEFT: Weight form -->
      <div class="lg:col-span-2">
        <div class="brutal-card p-6">

          <!-- Total bar -->
          <div class="mb-6 p-4 border-[3px] border-slate-900 shadow-[4px_4px_0px_rgba(15,23,42,1)] bg-white" id="bobot-total-card">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-bold text-slate-900 uppercase">Total Bobot</span>
              <span id="bobot-total-display" class="text-3xl font-black transition-all duration-100" style="font-family:'Rajdhani',sans-serif; color: var(--ocean);">0.000</span>
            </div>
            <div class="w-full h-4 bg-slate-200 border-2 border-slate-900 overflow-hidden relative">
              <div id="bobot-progress-bar" class="absolute top-0 bottom-0 left-0 transition-all duration-200 bg-blue-600" style="width: 0%;"></div>
            </div>
            <div class="flex justify-between text-xs font-bold text-slate-500 mt-2 uppercase">
              <span>0.0</span>
              <span class="text-blue-700 bg-blue-100 px-2 py-0.5 border border-blue-900">Target: 1.0</span>
              <span>Lebih</span>
            </div>
          </div>

          <!-- Criteria inputs -->
          <div class="space-y-4" id="bobot-inputs">

            <!-- C1 -->
            <div class="flex items-center gap-3 p-3 border-[3px] border-slate-900 bg-white hover:bg-slate-50 transition-all shadow-[4px_4px_0px_rgba(15,23,42,1)]">
              <div class="w-10 h-10 bg-blue-600 border-2 border-slate-900 flex items-center justify-center flex-shrink-0">
                <span class="text-white text-sm font-black">C1</span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <p class="font-bold text-slate-900 uppercase tracking-wide">Skor MAL</p>
                  <span class="px-1.5 py-0.5 bg-blue-200 text-blue-900 border border-blue-900 text-[0.65rem] font-bold uppercase">Benefit</span>
                </div>
                <p class="text-slate-500 font-semibold text-xs mt-0.5">Rating rata-rata (0-10)</p>
              </div>
              <div class="flex items-center gap-2 flex-shrink-0">
                <input type="range" id="w-c1-slider" min="0" max="1" step="0.01" value="0.20" class="w-24 h-2 cursor-pointer" />
                <input type="number" id="w-c1" name="w-c1" min="0" max="1" step="0.01" value="0.20" class="table-cell-input w-20 text-center" />
              </div>
            </div>

            <!-- C2 -->
            <div class="flex items-center gap-3 p-3 border-[3px] border-slate-900 bg-white hover:bg-slate-50 transition-all shadow-[4px_4px_0px_rgba(15,23,42,1)]">
              <div class="w-10 h-10 bg-blue-600 border-2 border-slate-900 flex items-center justify-center flex-shrink-0">
                <span class="text-white text-sm font-black">C2</span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <p class="font-bold text-slate-900 uppercase tracking-wide">Members</p>
                  <span class="px-1.5 py-0.5 bg-blue-200 text-blue-900 border border-blue-900 text-[0.65rem] font-bold uppercase">Benefit</span>
                </div>
                <p class="text-slate-500 font-semibold text-xs mt-0.5">Jumlah member MAL</p>
              </div>
              <div class="flex items-center gap-2 flex-shrink-0">
                <input type="range" id="w-c2-slider" min="0" max="1" step="0.01" value="0.15" class="w-24 h-2 cursor-pointer" />
                <input type="number" id="w-c2" name="w-c2" min="0" max="1" step="0.01" value="0.15" class="table-cell-input w-20 text-center" />
              </div>
            </div>

            <!-- C3 -->
            <div class="flex items-center gap-3 p-3 border-[3px] border-slate-900 bg-white hover:bg-slate-50 transition-all shadow-[4px_4px_0px_rgba(15,23,42,1)]">
              <div class="w-10 h-10 bg-blue-600 border-2 border-slate-900 flex items-center justify-center flex-shrink-0">
                <span class="text-white text-sm font-black">C3</span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <p class="font-bold text-slate-900 uppercase tracking-wide">Produktivitas</p>
                  <span class="px-1.5 py-0.5 bg-blue-200 text-blue-900 border border-blue-900 text-[0.65rem] font-bold uppercase">Benefit</span>
                </div>
                <p class="text-slate-500 font-semibold text-xs mt-0.5">Total anime diproduksi</p>
              </div>
              <div class="flex items-center gap-2 flex-shrink-0">
                <input type="range" id="w-c3-slider" min="0" max="1" step="0.01" value="0.15" class="w-24 h-2 cursor-pointer" />
                <input type="number" id="w-c3" name="w-c3" min="0" max="1" step="0.01" value="0.15" class="table-cell-input w-20 text-center" />
              </div>
            </div>

            <!-- C4 -->
            <div class="flex items-center gap-3 p-3 border-[3px] border-slate-900 bg-red-50 hover:bg-red-100 transition-all shadow-[4px_4px_0px_rgba(15,23,42,1)]">
              <div class="w-10 h-10 bg-red-500 border-2 border-slate-900 flex items-center justify-center flex-shrink-0">
                <span class="text-white text-sm font-black">C4</span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <p class="font-bold text-red-700 uppercase tracking-wide">Rasio Flop</p>
                  <span class="px-1.5 py-0.5 bg-red-200 text-red-900 border border-red-900 text-[0.65rem] font-bold uppercase">Cost</span>
                </div>
                <p class="text-red-500 font-semibold text-xs mt-0.5">% anime dengan skor &lt; 6</p>
              </div>
              <div class="flex items-center gap-2 flex-shrink-0">
                <input type="range" id="w-c4-slider" min="0" max="1" step="0.01" value="0.20" class="w-24 h-2 cursor-pointer" />
                <input type="number" id="w-c4" name="w-c4" min="0" max="1" step="0.01" value="0.20" class="table-cell-input w-20 text-center !text-red-600 focus:shadow-[2px_2px_0px_#ef4444]" />
              </div>
            </div>

            <!-- C5 -->
            <div class="flex items-center gap-3 p-3 border-[3px] border-slate-900 bg-white hover:bg-slate-50 transition-all shadow-[4px_4px_0px_rgba(15,23,42,1)]">
              <div class="w-10 h-10 bg-blue-600 border-2 border-slate-900 flex items-center justify-center flex-shrink-0">
                <span class="text-white text-sm font-black">C5</span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <p class="font-bold text-slate-900 uppercase tracking-wide">Favorites</p>
                  <span class="px-1.5 py-0.5 bg-blue-200 text-blue-900 border border-blue-900 text-[0.65rem] font-bold uppercase">Benefit</span>
                </div>
                <p class="text-slate-500 font-semibold text-xs mt-0.5">Total favorites di MAL</p>
              </div>
              <div class="flex items-center gap-2 flex-shrink-0">
                <input type="range" id="w-c5-slider" min="0" max="1" step="0.01" value="0.15" class="w-24 h-2 cursor-pointer" />
                <input type="number" id="w-c5" name="w-c5" min="0" max="1" step="0.01" value="0.15" class="table-cell-input w-20 text-center" />
              </div>
            </div>

            <!-- C6 -->
            <div class="flex items-center gap-3 p-3 border-[3px] border-slate-900 bg-white hover:bg-slate-50 transition-all shadow-[4px_4px_0px_rgba(15,23,42,1)]">
              <div class="w-10 h-10 bg-blue-600 border-2 border-slate-900 flex items-center justify-center flex-shrink-0">
                <span class="text-white text-sm font-black">C6</span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <p class="font-bold text-slate-900 uppercase tracking-wide">Masterpiece</p>
                  <span class="px-1.5 py-0.5 bg-blue-200 text-blue-900 border border-blue-900 text-[0.65rem] font-bold uppercase">Benefit</span>
                </div>
                <p class="text-slate-500 font-semibold text-xs mt-0.5">Anime skor ≥ 8</p>
              </div>
              <div class="flex items-center gap-2 flex-shrink-0">
                <input type="range" id="w-c6-slider" min="0" max="1" step="0.01" value="0.15" class="w-24 h-2 cursor-pointer" />
                <input type="number" id="w-c6" name="w-c6" min="0" max="1" step="0.01" value="0.15" class="table-cell-input w-20 text-center" />
              </div>
            </div>

          </div><!-- /bobot-inputs -->

          <!-- Validation message -->
          <div id="bobot-warning" class="mt-6 p-4 bg-red-100 border-[3px] border-slate-900 shadow-[4px_4px_0px_rgba(15,23,42,1)] flex items-center gap-3" style="display:none;">
            <div class="w-8 h-8 bg-red-500 text-white flex items-center justify-center border-2 border-slate-900 font-black">!</div>
            <span class="text-slate-900 font-black uppercase" id="bobot-warning-text">Total bobot belum = 1.0</span>
          </div>

          <div id="bobot-ok" class="mt-6 p-4 bg-green-100 border-[3px] border-slate-900 shadow-[4px_4px_0px_rgba(15,23,42,1)] flex items-center gap-3" style="display:none;">
            <div class="w-8 h-8 bg-green-500 text-white flex items-center justify-center border-2 border-slate-900 font-black">✓</div>
            <span class="text-slate-900 font-black uppercase">Total bobot = 1.0. Siap lanjut!</span>
          </div>

        </div>
      </div>

      <!-- RIGHT: Info panel -->
      <div class="space-y-6">

        <!-- Quick preset buttons -->
        <div class="brutal-card p-5">
          <h3 class="font-black text-slate-900 uppercase tracking-widest text-sm mb-4 border-b-2 border-slate-900 pb-2">⚡ Preset Cepat</h3>
          <div class="space-y-3">
            <button onclick="applyPreset('equal')" class="w-full text-left px-3 py-2 bg-white border-2 border-slate-900 text-slate-900 text-sm font-bold shadow-[3px_3px_0px_rgba(15,23,42,1)] transition-transform hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[5px_5px_0px_rgba(15,23,42,1)] active:translate-x-1 active:translate-y-1 active:shadow-[0px_0px_0px_rgba(15,23,42,1)]">
              ⚖️ Bobot Sama Rata (1/6)
            </button>
            <button onclick="applyPreset('score')" class="w-full text-left px-3 py-2 bg-yellow-100 border-2 border-slate-900 text-slate-900 text-sm font-bold shadow-[3px_3px_0px_rgba(15,23,42,1)] transition-transform hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[5px_5px_0px_rgba(15,23,42,1)] active:translate-x-1 active:translate-y-1 active:shadow-[0px_0px_0px_rgba(15,23,42,1)]">
              ⭐ Prioritas Skor 
            </button>
            <button onclick="applyPreset('popularity')" class="w-full text-left px-3 py-2 bg-blue-100 border-2 border-slate-900 text-slate-900 text-sm font-bold shadow-[3px_3px_0px_rgba(15,23,42,1)] transition-transform hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[5px_5px_0px_rgba(15,23,42,1)] active:translate-x-1 active:translate-y-1 active:shadow-[0px_0px_0px_rgba(15,23,42,1)]">
              👥 Prioritas Popularitas
            </button>
            <button onclick="applyPreset('balanced')" class="w-full text-left px-3 py-2 bg-green-100 border-2 border-slate-900 text-slate-900 text-sm font-bold shadow-[3px_3px_0px_rgba(15,23,42,1)] transition-transform hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[5px_5px_0px_rgba(15,23,42,1)] active:translate-x-1 active:translate-y-1 active:shadow-[0px_0px_0px_rgba(15,23,42,1)]">
              🎯 Balanced (Default)
            </button>
          </div>
        </div>

        <!-- Formula info -->
        <div class="brutal-card p-5 bg-slate-900 text-white">
          <h3 class="font-black uppercase tracking-widest text-sm mb-4 border-b-2 border-slate-600 pb-2">📐 Formula SAW</h3>
          <div class="space-y-3 font-mono text-xs">
            <div>
              <p class="text-blue-400 font-bold mb-1">BENEFIT:</p>
              <code class="bg-slate-800 p-1 px-2 border border-slate-700 block">r = x / max(x)</code>
            </div>
            <div>
              <p class="text-red-400 font-bold mb-1">COST:</p>
              <code class="bg-slate-800 p-1 px-2 border border-slate-700 block">r = min(x) / x</code>
            </div>
            <div>
              <p class="text-green-400 font-bold mb-1">NILAI AKHIR:</p>
              <code class="bg-slate-800 p-1 px-2 border border-slate-700 block">V = Σ(w × r)</code>
            </div>
          </div>
        </div>

        <!-- Next button -->
        <button id="btn-bobot-next"
          class="btn-primary w-full py-4 flex items-center justify-center gap-2">
          <span style="font-size: 0.85rem; white-space: nowrap;">Lanjut ke Matriks X</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </button>

      </div>
    </div>
  </div>
</section>

<script>
  const CRITERIA_KEYS = ['c1', 'c2', 'c3', 'c4', 'c5', 'c6'];

  function getBobotValues() {
    return CRITERIA_KEYS.map(k => {
      const el = document.getElementById(`w-${k}`);
      return el ? parseFloat(el.value) || 0 : 0;
    });
  }

  function updateBobotUI() {
    const values = getBobotValues();
    const total = values.reduce((a, b) => a + b, 0);
    const rounded = parseFloat(total.toFixed(3));

    const totalDisplay = document.getElementById('bobot-total-display');
    const progressBar = document.getElementById('bobot-progress-bar');
    const totalCard = document.getElementById('bobot-total-card');
    const warning = document.getElementById('bobot-warning');
    const warningText = document.getElementById('bobot-warning-text');
    const okEl = document.getElementById('bobot-ok');

    if (totalDisplay) totalDisplay.textContent = rounded.toFixed(3);
    if (progressBar) {
      progressBar.style.width = Math.min(total * 100, 100) + '%';
      if (total > 1.001) {
        progressBar.className = 'absolute top-0 bottom-0 left-0 transition-all duration-100 bg-red-500';
      } else {
        progressBar.className = 'absolute top-0 bottom-0 left-0 transition-all duration-100 bg-blue-600';
      }
    }

    const isValid = Math.abs(total - 1.0) < 0.001;

    if (totalDisplay) {
      totalDisplay.style.color = isValid ? '#16a34a' : (total > 1.001 ? '#ef4444' : '#2563eb');
    }
    if (totalCard) {
      totalCard.style.background = isValid
        ? '#dcfce7'
        : (total > 1.001 ? '#fee2e2' : 'white');
    }

    if (warning && warningText && okEl) {
      if (isValid) {
        warning.style.display = 'none';
        okEl.style.display = 'flex';
      } else {
        okEl.style.display = 'none';
        warning.style.display = 'flex';
        if (total > 1.001) {
          warningText.textContent = `Total berlebih! (${rounded.toFixed(3)} > 1.0)`;
        } else {
          warningText.textContent = `Kurang ${(1 - total).toFixed(3)} lagi.`;
        }
      }
    }
  }

  // Sync slider ↔ number input
  CRITERIA_KEYS.forEach(key => {
    const numInput = document.getElementById(`w-${key}`);
    const slider = document.getElementById(`w-${key}-slider`);
    if (!numInput || !slider) return;

    numInput.addEventListener('input', () => {
      slider.value = numInput.value;
      updateBobotUI();
    });
    slider.addEventListener('input', () => {
      numInput.value = parseFloat(slider.value).toFixed(2);
      updateBobotUI();
    });
  });

  // Presets
  window.applyPreset = function(type) {
    const presets = {
      equal: [0.17, 0.17, 0.17, 0.17, 0.16, 0.16],
      score:       [0.30, 0.10, 0.10, 0.25, 0.10, 0.15],
      popularity:  [0.15, 0.25, 0.10, 0.15, 0.25, 0.10],
      balanced:    [0.20, 0.15, 0.15, 0.20, 0.15, 0.15],
    };
    const vals = presets[type] || presets.balanced;
    CRITERIA_KEYS.forEach((key, i) => {
      const numInput = document.getElementById(`w-${key}`);
      const slider = document.getElementById(`w-${key}-slider`);
      if (numInput) numInput.value = vals[i].toFixed(2);
      if (slider) slider.value = vals[i].toFixed(2);
    });
    updateBobotUI();
  };

  // Save & proceed
  document.getElementById('btn-bobot-next')?.addEventListener('click', () => {
    const values = getBobotValues();
    const total = values.reduce((a, b) => a + b, 0);
    const isValid = Math.abs(total - 1.0) < 0.001;

    if (!isValid) {
      alert('Total bobot belum = 1.0');
      return;
    }

    const weights = {};
    CRITERIA_KEYS.forEach((k, i) => weights[k] = values[i]);
    sessionStorage.setItem('spk_weights', JSON.stringify(weights));
    window.dispatchEvent(new CustomEvent('spk:goto-step', { detail: { step: 2 } }));
  });

  // Load saved weights on show
  window.initBobotStep = function() {
    const saved = sessionStorage.getItem('spk_weights');
    if (saved) {
      try {
        const weights = JSON.parse(saved);
        CRITERIA_KEYS.forEach(key => {
          const numInput = document.getElementById(`w-${key}`);
          const slider = document.getElementById(`w-${key}-slider`);
          const val = weights[key] ?? 0;
          if (numInput) numInput.value = val.toFixed(2);
          if (slider) slider.value = val.toFixed(2);
        });
      } catch {}
    }
    updateBobotUI();
  };

  // Run on load
  updateBobotUI();
</script>
