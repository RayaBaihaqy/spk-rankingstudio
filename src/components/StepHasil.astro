---
// src/components/StepHasil.astro
---

<section id="step-hasil" class="pt-20 pb-12 bg-transparent" style="display:none;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="mb-8 anim-slide-up flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 bg-blue-600 text-white flex items-center justify-center border-[3px] border-slate-900 shadow-[4px_4px_0px_rgba(15,23,42,1)] transform -rotate-3">
          <span class="font-black text-2xl" style="font-family:'Rajdhani',sans-serif;">3</span>
        </div>
        <div>
          <h2 class="text-3xl font-black text-white uppercase tracking-wide" style="font-family:'Rajdhani',sans-serif;">Hasil Perhitungan SAW</h2>
          <p class="text-slate-600 font-bold bg-white inline-block px-2 py-0.5 border-2 border-slate-900 shadow-[2px_2px_0px_rgba(15,23,42,1)] mt-1">Normalisasi matriks R dan nilai V</p>
        </div>
      </div>
      <div class="flex flex-wrap gap-3">
        <button id="btn-hasil-back" class="btn-secondary flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
          </svg>
          Kembali
        </button>
        <button id="btn-export-excel" class="btn-primary flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Export Excel
        </button>
      </div>
    </div>

    <!-- Computing spinner -->
    <div id="hasil-loading" class="hidden text-center py-16">
      <div class="w-16 h-16 mx-auto border-[4px] border-slate-200 border-t-white rounded-full animate-spin mb-4"></div>
      <p class="text-white font-black uppercase tracking-widest text-lg" style="font-family: 'Rajdhani', sans-serif;">Menghitung...</p>
    </div>

    <!-- Results content -->
    <div id="hasil-content" class="hidden">

      <!-- TOP 3 Podium -->
      <div id="podium-section" class="mb-12">
        <div class="flex justify-center mb-6">
           <h3 class="text-xl font-black text-slate-900 uppercase tracking-widest bg-yellow-300 border-[3px] border-slate-900 px-6 py-2 shadow-[4px_4px_0px_rgba(15,23,42,1)] transform -rotate-1" style="font-family:'Rajdhani',sans-serif;">
            TOP 3 STUDIO ANIMASI
          </h3>
        </div>
        <div class="flex items-end justify-center gap-4" id="podium-container">
          <!-- Injected by JS -->
        </div>
      </div>

      <!-- Weight summary -->
      <div class="mb-8 brutal-card p-5">
        <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest mb-3 border-b-2 border-slate-900 pb-2">Bobot yang Digunakan:</h3>
        <div class="flex flex-wrap gap-2" id="weight-summary">
          <!-- injected -->
        </div>
      </div>

      <!-- Tab switcher -->
      <div class="flex mb-4 bg-slate-900 p-1 w-fit border-2 border-slate-900 shadow-[4px_4px_0px_rgba(15,23,42,1)]">
        <button id="tab-btn-ranking" onclick="switchTab('ranking')"
          class="px-5 py-2 text-sm font-black uppercase tracking-wider transition-all bg-white text-slate-900 border-2 border-slate-900">
          🏅 Ranking (V)
        </button>
        <button id="tab-btn-normalisasi" onclick="switchTab('normalisasi')"
          class="px-5 py-2 text-sm font-black uppercase tracking-wider transition-all text-white hover:bg-slate-800 border-2 border-transparent">
          📐 Normalisasi (R)
        </button>
      </div>

      <!-- Ranking table -->
      <div id="tab-ranking" class="brutal-card overflow-hidden bg-white">
        <div class="overflow-x-auto">
          <table class="w-full text-sm font-bold" style="font-family: 'Rajdhani', sans-serif;">
            <thead>
              <tr class="bg-slate-900 text-white uppercase tracking-wider text-sm border-b-[3px] border-slate-900">
                <th class="px-4 py-3 text-left w-20 border-r border-slate-700">Rank</th>
                <th class="px-4 py-3 text-left min-w-[200px] border-r border-slate-700">Studio</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C1 (R)</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C2 (R)</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C3 (R)</th>
                <th class="px-3 py-3 text-center bg-red-950 border-r border-red-900">C4 (R)</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C5 (R)</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C6 (R)</th>
                <th class="px-4 py-3 text-center font-black min-w-[100px] bg-blue-900 border-l-[3px] border-slate-900">NILAI V</th>
              </tr>
            </thead>
            <tbody id="ranking-tbody" class="divide-y-[2px] divide-slate-300">
              <!-- Injected by JS -->
            </tbody>
          </table>
        </div>
      </div>

      <!-- Normalization table -->
      <div id="tab-normalisasi" class="hidden brutal-card overflow-hidden bg-white">
        <div class="overflow-x-auto">
          <table class="w-full text-sm font-bold" style="font-family: 'Rajdhani', sans-serif;">
            <thead>
              <tr class="bg-slate-900 text-white uppercase tracking-wider text-sm border-b-[3px] border-slate-900">
                <th class="px-4 py-3 text-left min-w-[200px] border-r border-slate-700">Studio</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C1</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C2</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C3</th>
                <th class="px-3 py-3 text-center bg-red-950 border-r border-red-900">C4</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C5</th>
                <th class="px-3 py-3 text-center">C6</th>
              </tr>
            </thead>
            <tbody id="normalisasi-tbody" class="divide-y-[2px] divide-slate-300">
              <!-- Injected by JS -->
            </tbody>
          </table>
        </div>
      </div>

      <!-- Legend -->
      <div class="mt-4 flex flex-wrap gap-4 text-xs font-bold uppercase tracking-widest bg-white p-3 border-2 border-slate-900 shadow-[3px_3px_0px_rgba(15,23,42,1)] w-fit">
        <span class="flex items-center gap-2"><span class="inline-block w-4 h-4 bg-yellow-400 border border-slate-900"></span> Rank 1</span>
        <span class="flex items-center gap-2"><span class="inline-block w-4 h-4 bg-slate-300 border border-slate-900"></span> Rank 2</span>
        <span class="flex items-center gap-2"><span class="inline-block w-4 h-4 bg-orange-600 border border-slate-900"></span> Rank 3</span>
        <span class="ml-4 pl-4 border-l-2 border-slate-300 text-slate-500">R = Nilai Normal (0–1) | V = Σ(w × r)</span>
      </div>
    </div>

  </div>
</section>

<script>
  window.switchTab = function(tab) {
    const tabRanking = document.getElementById('tab-ranking');
    const tabNorm = document.getElementById('tab-normalisasi');
    const btnRanking = document.getElementById('tab-btn-ranking');
    const btnNorm = document.getElementById('tab-btn-normalisasi');

    if (tab === 'ranking') {
      tabRanking?.classList.remove('hidden');
      tabNorm?.classList.add('hidden');
      
      btnRanking?.classList.add('bg-white', 'text-slate-900', 'border-slate-900');
      btnRanking?.classList.remove('text-white', 'hover:bg-slate-800', 'border-transparent');
      
      btnNorm?.classList.add('text-white', 'hover:bg-slate-800', 'border-transparent');
      btnNorm?.classList.remove('bg-white', 'text-slate-900', 'border-slate-900');
    } else {
      tabNorm?.classList.remove('hidden');
      tabRanking?.classList.add('hidden');
      
      btnNorm?.classList.add('bg-white', 'text-slate-900', 'border-slate-900');
      btnNorm?.classList.remove('text-white', 'hover:bg-slate-800', 'border-transparent');
      
      btnRanking?.classList.add('text-white', 'hover:bg-slate-800', 'border-transparent');
      btnRanking?.classList.remove('bg-white', 'text-slate-900', 'border-slate-900');
    }
  };

  window.initHasilStep = function() {
    const loadingEl = document.getElementById('hasil-loading');
    const contentEl = document.getElementById('hasil-content');

    loadingEl?.classList.remove('hidden');
    contentEl?.classList.add('hidden');

    setTimeout(() => {
      try {
        runSAWAndRender();
        loadingEl?.classList.add('hidden');
        contentEl?.classList.remove('hidden');
      } catch (err) {
        loadingEl?.classList.add('hidden');
        console.error('[SPK] SAW error:', err);
      }
    }, 400);
  };

  function runSAWAndRender() {
    const studios = JSON.parse(sessionStorage.getItem('spk_studioNames') || '[]');
    const matrixX = JSON.parse(sessionStorage.getItem('spk_matrixX') || '[]');
    const weightsObj = JSON.parse(sessionStorage.getItem('spk_weights') || '{}');

    const CRITERIA_TYPES = ['Benefit', 'Benefit', 'Benefit', 'Cost', 'Benefit', 'Benefit'];
    const CRITERIA_KEYS = ['c1', 'c2', 'c3', 'c4', 'c5', 'c6'];
    const weights = CRITERIA_KEYS.map(k => weightsObj[k] || 0);

    const n = studios.length;
    const m = 6;

    const maxCol = Array.from({ length: m }, (_, j) => Math.max(...matrixX.map(r => r[j] || 0)));
    const minCol = Array.from({ length: m }, (_, j) => Math.min(...matrixX.map(r => r[j] || 0)));

    const matrixR = matrixX.map(row =>
      row.map((val, j) => {
        if (CRITERIA_TYPES[j] === 'Benefit') {
          return maxCol[j] === 0 ? 0 : val / maxCol[j];
        } else {
          return val === 0 ? 0 : minCol[j] / val;
        }
      })
    );

    const valuesV = matrixR.map(row =>
      row.reduce((sum, rij, j) => sum + rij * weights[j], 0)
    );

    const ranked = studios.map((name, i) => ({
      name, v: valuesV[i], r: matrixR[i], x: matrixX[i], originalIndex: i
    })).sort((a, b) => b.v - a.v).map((item, idx) => ({ ...item, rank: idx + 1 }));

    sessionStorage.setItem('spk_results', JSON.stringify(ranked));

    renderPodium(ranked);
    renderWeightSummary(weightsObj, CRITERIA_KEYS);
    renderRankingTable(ranked);
    renderNormalisasiTable(studios, matrixR);
  }

  function renderPodium(ranked) {
    const container = document.getElementById('podium-container');
    if (!container) return;

    const MEDALS = { 1: '🥇', 2: '🥈', 3: '🥉' };
    const HEIGHTS = { 1: '140px', 2: '100px', 3: '80px' };
    const COLORS = {
      1: '#facc15', // yellow-400
      2: '#cbd5e1', // slate-300
      3: '#ea580c', // orange-600
    };
    const ORDER = [2, 1, 3]; 

    container.innerHTML = ORDER.map(rank => {
      const item = ranked.find(r => r.rank === rank);
      if (!item) return '';
      return `
        <div class="flex flex-col items-center gap-2 anim-slide-up" style="animation-delay:${(rank - 1) * 0.15}s; z-index: ${4-rank};">
          <div class="text-4xl filter drop-shadow-md">${MEDALS[rank]}</div>
          <div class="text-center bg-white border-2 border-slate-900 px-3 py-1 shadow-[3px_3px_0px_rgba(15,23,42,1)] -mb-2 z-10">
            <p class="font-black text-slate-900 text-sm uppercase" style="font-family:'Rajdhani',sans-serif;">${item.name}</p>
            <p class="text-xs font-bold text-slate-600">V = <strong class="text-blue-700">${item.v.toFixed(4)}</strong></p>
          </div>
          <div class="w-24 sm:w-32 flex items-center justify-center font-black text-slate-900 text-4xl border-[3px] border-slate-900 border-b-0"
            style="height:${HEIGHTS[rank]}; background:${COLORS[rank]}; box-shadow: 6px 0px 0px var(--ink);">
            ${rank}
          </div>
        </div>
      `;
    }).join('');
  }

  function renderWeightSummary(weightsObj, keys) {
    const container = document.getElementById('weight-summary');
    if (!container) return;
    const labels = { c1: 'C1', c2: 'C2', c3: 'C3', c4: 'C4', c5: 'C5', c6: 'C6' };
    container.innerHTML = keys.map(k => {
      const isC4 = k === 'c4';
      return `<span class="px-3 py-1.5 text-xs font-black uppercase tracking-wider border-2 border-slate-900 shadow-[2px_2px_0px_rgba(15,23,42,1)] ${
        isC4 ? 'bg-red-50 text-red-700' : 'bg-blue-50 text-blue-700'
      }">
        ${labels[k]}: <span class="text-slate-900">${(weightsObj[k] || 0).toFixed(2)}</span>
      </span>`;
    }).join('');
  }

  function renderRankingTable(ranked) {
    const tbody = document.getElementById('ranking-tbody');
    if (!tbody) return;

    tbody.innerHTML = ranked.map(item => {
      const rowClass = item.rank === 1 ? 'bg-yellow-100 hover:bg-yellow-200' : item.rank === 2 ? 'bg-slate-100 hover:bg-slate-200' : item.rank === 3 ? 'bg-orange-100 hover:bg-orange-200' : 'bg-white hover:bg-blue-50';
      const badge = item.rank <= 3
        ? `<span class="rank-badge-${item.rank} inline-block">${['🥇','🥈','🥉'][item.rank-1]} #${item.rank}</span>`
        : `<span class="text-slate-500 font-black">#${item.rank}</span>`;

      return `<tr class="${rowClass} transition-colors group">
        <td class="px-4 py-3 border-r border-slate-300">${badge}</td>
        <td class="px-4 py-3 font-black text-slate-900 text-base border-r border-slate-300 uppercase">${item.name}</td>
        ${item.r.map((v, j) => `
          <td class="px-3 py-3 text-center text-slate-700 border-r border-slate-300 ${j === 3 ? 'bg-red-50/50 text-red-700 group-hover:bg-red-100' : ''}">${v.toFixed(4)}</td>
        `).join('')}
        <td class="px-4 py-3 text-center bg-blue-50 border-l-[3px] border-slate-900 group-hover:bg-blue-100 transition-colors">
          <span class="font-black text-blue-700 text-xl" style="font-family:'Rajdhani',sans-serif;">${item.v.toFixed(4)}</span>
        </td>
      </tr>`;
    }).join('');
  }

  function renderNormalisasiTable(studios, matrixR) {
    const tbody = document.getElementById('normalisasi-tbody');
    if (!tbody) return;

    tbody.innerHTML = studios.map((name, i) => `
      <tr class="${i % 2 === 0 ? 'bg-white' : 'bg-slate-50'} hover:bg-blue-50 transition-colors group">
        <td class="px-4 py-3 font-black text-slate-900 text-base border-r border-slate-300 uppercase">${name}</td>
        ${(matrixR[i] || []).map((v, j) => `
          <td class="px-3 py-3 text-center text-slate-700 border-r border-slate-300 ${j === 3 ? 'bg-red-50/50 text-red-700 group-hover:bg-red-100' : ''}">${v.toFixed(4)}</td>
        `).join('')}
      </tr>
    `).join('');
  }

  // Export to Excel
  document.getElementById('btn-export-excel')?.addEventListener('click', () => {
    const ranked = JSON.parse(sessionStorage.getItem('spk_results') || '[]');
    if (!ranked.length) { alert('Belum ada data hasil.'); return; }

    if (typeof XLSX === 'undefined') { alert('Library Excel belum dimuat.'); return; }

    const headers = ['Rank', 'Studio', 'C1 (R)', 'C2 (R)', 'C3 (R)', 'C4 (R)', 'C5 (R)', 'C6 (R)', 'Nilai V'];
    const rows = ranked.map(item => [
      item.rank, item.name,
      ...item.r.map(v => parseFloat(v.toFixed(4))),
      parseFloat(item.v.toFixed(4))
    ]);

    const ws = XLSX.utils.aoa_to_sheet([headers, ...rows]);
    ws['!cols'] = [{ wch: 6 }, { wch: 22 }, ...Array(6).fill({ wch: 10 }), { wch: 10 }];

    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'Hasil SPK');
    XLSX.writeFile(wb, 'Hasil_SPK_Studio_Animasi.xlsx');
  });

  // Navigation
  document.getElementById('btn-hasil-back')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('spk:goto-step', { detail: { step: 2 } }));
  });
</script>
