---
// src/components/manga/MangaStepUpload.astro
---

<section id="manga-step-upload" style="display:none; height: 100vh; max-height: 100vh; padding-top: 66px; flex-direction: column; position: relative; overflow: hidden; background: transparent;">
  <div style="flex:1; align-items:center; justify-content:center; position:relative; z-index:2; padding: 1rem 1rem 100px; display:flex;">
    <div class="w-full max-w-5xl grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
      <!-- Left Column: Header -->
      <div style="text-align:left; display: flex; flex-direction: column; justify-content: center;">
        <button id="manga-upload-back"
          style="display:inline-flex; align-items:center; gap:6px; background:transparent; border:none; color:rgba(255,255,255,0.55); font-weight:700; font-size:0.8rem; text-transform:uppercase; cursor:pointer; padding:0; margin-bottom:10px; letter-spacing:0.08em;"
          onmouseover="this.style.color='#fff'"
          onmouseout="this.style.color='rgba(255,255,255,0.55)'">
          <svg xmlns="http://www.w3.org/2000/svg" style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12"/>
          </svg>
          Kembali ke Pilihan Modul
        </button>

        <!-- Genre winner banner -->
        <div id="manga-genre-banner" class="hidden mb-4 p-2 border-2 border-slate-900 shadow-[3px_3px_0px_rgba(15,23,42,1)] flex items-center gap-2" style="background:#d1fae5; width: fit-content;">
          <span style="font-size:1.1rem;">🎭</span>
          <span class="font-black text-slate-900 text-xs uppercase tracking-wide">Genre Prioritas: <span id="manga-genre-winner-label" class="text-emerald-700"></span></span>
        </div>

        <h1 style="font-family:'Rajdhani',sans-serif; font-weight:900; line-height:1.1; margin-bottom:1.5rem; color:#ffffff; text-transform: uppercase;">
          <span style="display:block; font-size:clamp(1.2rem,3vw,1.6rem); font-weight:800; letter-spacing:0.05em; margin-bottom: 6px;">Pemilihan Prioritas</span>
          <span style="display:block; font-size:clamp(2.2rem,5vw,3.2rem); font-weight:900;">Manga Terbaik</span>
        </h1>

        <p style="color:var(--text-secondary); font-weight: 600; font-size:0.95rem; max-width:460px; line-height:1.6; border: var(--border-thin); background: #e5e5e5; padding: 12px 18px; margin: 0; box-shadow: 3px 3px 0px var(--ink);">
          Upload data Excel manga, definisikan <span class="manga-highlight" style="background:#10b981; color:white; padding: 0 4px;">6 kriteria</span>, atur bobot, dan dapatkan prioritas akurat menggunakan AHP dan SAW. Semua dihitung otomatis di browser.
        </p>
      </div>

      <!-- Right Column: DROPZONE CARD -->
      <div class="brutal-card" style="overflow:hidden; position:relative; width: 100%;">
        <!-- Card header -->
        <div style="padding:10px 16px; display:flex; align-items:center; justify-content:space-between; border-bottom: var(--border-thick); background: #d4d4d8;">
          <div style="display:flex; align-items:center; gap:10px;">
            <div style="width:28px; height:28px; background: var(--ink); color: white; display:flex; align-items:center; justify-content:center; font-family: monospace; font-weight: bold; border-radius: 2px;">
              >_
            </div>
            <div>
              <p style="font-weight:800; color:var(--ink); font-size:1rem; margin:0; text-transform: uppercase; font-family: 'Rajdhani', sans-serif;">Upload Data</p>
            </div>
          </div>
          <div style="font-weight: 700; font-size: 0.75rem; color: var(--ink); background: #cbd5e1; padding: 2px 8px; border: var(--border-thin);">
            .XLSX / .CSV
          </div>
        </div>

        <!-- Dropzone -->
        <div style="padding:12px 20px;">
          <div id="manga-dropzone" style="position:relative; border: 3px dashed var(--ink); background: #e5e5e5; min-height:130px; display:flex; align-items:center; justify-content:center; cursor:pointer; transition:all 0.15s;"
            onmouseover="this.style.background='#d4d4d8'; this.style.transform='scale(1.01)'"
            onmouseout="this.style.background='#e5e5e5'; this.style.transform='scale(1)'"
            role="button" tabindex="0">
            <input type="file" id="manga-file-input" accept=".xlsx,.xls,.csv" style="position:absolute; inset:0; opacity:0; cursor:pointer; z-index:5;"/>

            <!-- Idle -->
            <div id="manga-dz-idle" style="text-align:center; padding:0.75rem 1rem;">
              <div style="width:44px; height:44px; margin:0 auto 0.5rem; background:#10b981; border:var(--border-thick); box-shadow:3px 3px 0px var(--ink); display:flex; align-items:center; justify-content:center; transform:rotate(-5deg);" class="anim-float">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:24px;height:24px;color:white;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
                </svg>
              </div>
              <p style="color:var(--ink); font-weight:800; font-size:1rem; margin:0 0 2px; font-family:'Rajdhani',sans-serif; text-transform:uppercase;">Drag &amp; Drop File Excel</p>
              <p style="color:var(--text-secondary); font-weight:600; font-size:0.8rem; margin:0;">atau klik area ini untuk memilih file</p>
            </div>

            <!-- Loading -->
            <div id="manga-dz-loading" style="display:none; text-align:center; padding:1.5rem;">
              <div style="width:36px; height:36px; margin:0 auto 8px; border:4px solid var(--ink); border-top-color:#10b981; animation:spin-manga 1s linear infinite;"></div>
              <p style="color:var(--ink); font-weight:800; font-size:0.9rem; font-family:'Rajdhani',sans-serif; text-transform:uppercase;">Membaca file...</p>
            </div>

            <!-- Success -->
            <div id="manga-dz-success" style="display:none; text-align:center; padding:1.5rem;">
              <div style="width:44px; height:44px; margin:0 auto 8px; background:#22c55e; border:var(--border-thick); box-shadow:3px 3px 0px var(--ink); display:flex; align-items:center; justify-content:center;">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:24px;height:24px;" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
              <p style="color:var(--ink); font-weight:800; font-size:1rem; margin:0 0 2px; font-family:'Rajdhani',sans-serif; text-transform:uppercase;" id="manga-file-name">File terbaca!</p>
              <p style="color:var(--text-secondary); font-weight:600; font-size:0.8rem; margin:0;" id="manga-file-info"></p>
            </div>
          </div>
        </div>

        <div style="padding:0 20px 12px;">
          <button id="manga-use-sample" style="width:100%; display:flex; align-items:center; justify-content:center; gap:8px; padding:10px 16px; border:var(--border-thick); background:#f8fafc; color:var(--ink); font-weight:800; font-size:0.85rem; cursor:pointer; font-family:'Rajdhani',sans-serif; text-transform:uppercase; transition:all 0.1s;"
            onmouseover="this.style.background='#f1f5f9';"
            onmouseout="this.style.background='#f8fafc';">
            <svg xmlns="http://www.w3.org/2000/svg" style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            COBA DENGAN DATA SAMPLE (15 MANGA)
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Manga Mapping Modal Overlay -->
  <div id="manga-mapping-modal" class="modal-overlay" style="display:none; position:fixed; inset:0; background:rgba(15,23,42,0.8); z-index:50; flex-direction:column; align-items:center; justify-content:center; padding:1rem;">
    <div class="brutal-card w-full p-5" style="max-width:600px; max-height:90vh; overflow-y:auto;">
      <div class="flex items-center justify-between mb-4 border-b-2 border-slate-900 pb-2">
        <h3 class="font-black text-slate-900 uppercase tracking-widest text-lg">🗂️ Mapping Kolom Excel (Manga)</h3>
        <button id="manga-map-close" class="text-red-500 font-black text-xl hover:text-red-700">&times;</button>
      </div>

      <div class="space-y-3">
        <!-- Nama Manga -->
        <div>
          <label class="block text-xs font-black text-slate-900 mb-1.5 uppercase tracking-wide">Nama Manga <span class="text-red-600">*</span></label>
          <select id="manga-map-name" class="w-full border-[3px] border-slate-900 px-3 py-2 text-sm font-bold text-slate-900 bg-white focus:outline-none">
            <option value="">-- Pilih Kolom --</option>
          </select>
        </div>
        <!-- C1 -->
        <div>
          <label class="block text-xs font-black text-slate-900 mb-1.5 uppercase tracking-wide">C1 — Skor Rata-rata <span class="text-red-600">*</span></label>
          <select id="manga-map-c1" class="w-full border-[3px] border-slate-900 px-3 py-2 text-sm font-bold text-slate-900 bg-white focus:outline-none">
            <option value="">-- Pilih Kolom --</option>
          </select>
        </div>
        <!-- C2 -->
        <div>
          <label class="block text-xs font-black text-slate-900 mb-1.5 uppercase tracking-wide">C2 — Members <span class="text-red-600">*</span></label>
          <select id="manga-map-c2" class="w-full border-[3px] border-slate-900 px-3 py-2 text-sm font-bold text-slate-900 bg-white focus:outline-none">
            <option value="">-- Pilih Kolom --</option>
          </select>
        </div>
        <!-- C3 -->
        <div>
          <label class="block text-xs font-black text-slate-900 mb-1.5 uppercase tracking-wide">C3 — Favorites <span class="text-red-600">*</span></label>
          <select id="manga-map-c3" class="w-full border-[3px] border-slate-900 px-3 py-2 text-sm font-bold text-slate-900 bg-white focus:outline-none">
            <option value="">-- Pilih Kolom --</option>
          </select>
        </div>
        <!-- C4 -->
        <div>
          <label class="block text-xs font-black text-slate-900 mb-1.5 uppercase tracking-wide">C4 — Jumlah Chapter <span class="text-red-600">*</span></label>
          <select id="manga-map-c4" class="w-full border-[3px] border-slate-900 px-3 py-2 text-sm font-bold text-slate-900 bg-white focus:outline-none">
            <option value="">-- Pilih Kolom --</option>
          </select>
        </div>
        <!-- C5 -->
        <div>
          <label class="block text-xs font-black text-slate-900 mb-1.5 uppercase tracking-wide">C5 — Tahun Rilis <span class="text-red-600">*</span></label>
          <select id="manga-map-c5" class="w-full border-[3px] border-slate-900 px-3 py-2 text-sm font-bold text-slate-900 bg-white focus:outline-none">
            <option value="">-- Pilih Kolom --</option>
          </select>
        </div>
        <!-- C6 -->
        <div>
          <label class="block text-xs font-black text-red-700 mb-1.5 uppercase tracking-wide">C6 — Rank MAL (Cost) <span class="text-red-600">*</span></label>
          <select id="manga-map-c6" class="w-full border-[3px] border-red-400 px-3 py-2 text-sm font-bold text-red-700 bg-red-50 focus:outline-none">
            <option value="">-- Pilih Kolom --</option>
          </select>
        </div>
      </div>

      <!-- Error -->
      <div id="manga-map-error" class="mt-4 p-3 bg-red-100 border-2 border-slate-900 hidden flex items-center gap-2">
        <span class="w-6 h-6 bg-red-500 text-white flex items-center justify-center font-black text-xs flex-shrink-0">!</span>
        <span class="font-black text-red-700 text-sm uppercase" id="manga-map-error-text"></span>
      </div>

      <!-- Confirm -->
      <button id="manga-map-confirm"
        style="width:100%; margin-top:16px; padding:12px 24px; background:#10b981; color:white; border:var(--border-thick); font-weight:800; font-size:0.95rem; text-transform:uppercase; letter-spacing:0.05em; box-shadow:var(--shadow-offset); cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px; transition:all 0.1s;"
        onmouseover="this.style.transform='translate(-2px,-2px)'; this.style.boxShadow='6px 6px 0px var(--ink)'"
        onmouseout="this.style.transform='translate(0,0)'; this.style.boxShadow='4px 4px 0px var(--ink)'">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        LANJUT KE BOBOT AHP
      </button>
    </div>
  </div>
</section>

<script>
  // =============================================
  // Manga Upload — State & Logic
  // =============================================

  const MANGA_SAMPLE_DATA = [
    { nama: 'Berserk',              c1: 9.45, c2: 2180000, c3: 356000, c4: 374,  c5: 1989, c6: 1  },
    { nama: 'One Piece',            c1: 9.21, c2: 1940000, c3: 265000, c4: 1107, c5: 1999, c6: 10 },
    { nama: 'Attack on Titan',      c1: 9.09, c2: 1823000, c3: 198000, c4: 141,  c5: 2009, c6: 8  },
    { nama: 'Fullmetal Alchemist',  c1: 9.10, c2: 1675000, c3: 185000, c4: 116,  c5: 2001, c6: 9  },
    { nama: 'Vagabond',             c1: 9.27, c2: 498000,  c3: 148000, c4: 327,  c5: 1998, c6: 3  },
    { nama: 'Death Note',           c1: 8.76, c2: 1542000, c3: 142000, c4: 108,  c5: 2003, c6: 16 },
    { nama: 'Vinland Saga',         c1: 8.93, c2: 875000,  c3: 128000, c4: 200,  c5: 2005, c6: 12 },
    { nama: 'Monster',              c1: 8.90, c2: 1125000, c3: 115000, c4: 162,  c5: 1994, c6: 14 },
    { nama: 'Slam Dunk',            c1: 8.77, c2: 543000,  c3: 78000,  c4: 276,  c5: 1990, c6: 15 },
    { nama: 'Mushishi',             c1: 8.78, c2: 312000,  c3: 68000,  c4: 50,   c5: 1999, c6: 11 },
    { nama: 'Kimetsu no Yaiba',     c1: 8.37, c2: 1842000, c3: 162000, c4: 207,  c5: 2016, c6: 34 },
    { nama: 'JoJo Bizarre Adventure',c1: 8.63, c2: 746000, c3: 98000,  c4: 900,  c5: 1987, c6: 22 },
    { nama: 'Chainsaw Man',         c1: 8.77, c2: 1524000, c3: 145000, c4: 103,  c5: 2018, c6: 13 },
    { nama: 'Nana',                 c1: 8.51, c2: 487000,  c3: 72000,  c4: 84,   c5: 2000, c6: 28 },
    { nama: 'Nausicaa',             c1: 8.97, c2: 348000,  c3: 86000,  c4: 59,   c5: 1982, c6: 5  },
  ];

  let mangaRawData = null;

  const MANGA_MAP_IDS  = ['manga-map-name','manga-map-c1','manga-map-c2','manga-map-c3','manga-map-c4','manga-map-c5','manga-map-c6'];
  const MANGA_MAP_KEYS = ['name','c1','c2','c3','c4','c5','c6'];
  const MANGA_GUESS_MAPS = {
    'manga-map-name': ['nama', 'name', 'judul', 'title', 'manga'],
    'manga-map-c1':   ['skor', 'score', 'rating', 'c1'],
    'manga-map-c2':   ['member', 'members', 'c2', 'popularitas'],
    'manga-map-c3':   ['favorit', 'favorites', 'c3', 'fav'],
    'manga-map-c4':   ['chapter', 'chapters', 'c4', 'vol'],
    'manga-map-c5':   ['tahun', 'year', 'c5', 'rilis'],
    'manga-map-c6':   ['rank', 'ranking', 'c6'],
  };

  function setMangaDzState(state, filename = '', info = '') {
    const idle    = document.getElementById('manga-dz-idle');
    const loading = document.getElementById('manga-dz-loading');
    const success = document.getElementById('manga-dz-success');
    if (idle)    idle.style.display    = state === 'idle'    ? 'block' : 'none';
    if (loading) loading.style.display = state === 'loading' ? 'flex'  : 'none';
    if (success) success.style.display = state === 'success' ? 'block' : 'none';
    if (state === 'success') {
      const fn = document.getElementById('manga-file-name');
      const fi = document.getElementById('manga-file-info');
      if (fn) fn.textContent = filename;
      if (fi) fi.textContent = info;
    }
  }

  function populateMangaSelects(headers) {
    MANGA_MAP_IDS.forEach(id => {
      const sel = document.getElementById(id);
      if (!sel) return;
      sel.innerHTML = `<option value="">-- Pilih Kolom --</option>`;
      headers.forEach(h => {
        const opt = document.createElement('option');
        opt.value = h; opt.textContent = h.toUpperCase();
        sel.appendChild(opt);
      });
    });
    // Auto-guess
    Object.entries(MANGA_GUESS_MAPS).forEach(([selectId, keywords]) => {
      const sel = document.getElementById(selectId);
      if (!sel || sel.value) return;
      for (const h of headers) {
        if (keywords.some(k => h.toLowerCase().includes(k))) {
          sel.value = h; break;
        }
      }
    });
  }

  async function handleMangaFile(file) {
    setMangaDzState('loading');
    let attempts = 0;
    while (typeof XLSX === 'undefined' && attempts < 20) {
      await new Promise(r => setTimeout(r, 100)); attempts++;
    }
    if (typeof XLSX === 'undefined') {
      setMangaDzState('idle');
      alert('Library Excel belum dimuat. Refresh halaman.');
      return;
    }
    try {
      const buffer = await file.arrayBuffer();
      const wb = XLSX.read(new Uint8Array(buffer), { type: 'array' });
      const sheet = wb.Sheets[wb.SheetNames[0]];
      const jsonData = XLSX.utils.sheet_to_json(sheet, { header: 1, defval: '' });
      if (!jsonData || jsonData.length < 2) {
        setMangaDzState('idle'); alert('File kosong atau tidak valid.'); return;
      }
      const headers = jsonData[0].map(h => String(h).trim()).filter(h => h);
      const rawRows = jsonData.slice(1).filter(row => row.some(c => c !== '' && c !== null));
      const rows = rawRows.map(row => {
        const obj = {};
        headers.forEach((h, i) => obj[h] = row[i] !== undefined ? row[i] : '');
        return obj;
      });
      mangaRawData = { headers, rows, filename: file.name };
      setMangaDzState('success', file.name, `${rows.length} baris data ditemukan`);
      populateMangaSelects(headers);
      const modal = document.getElementById('manga-mapping-modal');
      if (modal) modal.style.display = 'flex';
    } catch (err) {
      setMangaDzState('idle'); alert('Error membaca file: ' + err.message);
    }
  }

  function loadMangaSampleData() {
    const headers = ['nama', 'c1', 'c2', 'c3', 'c4', 'c5', 'c6'];
    mangaRawData = { headers, rows: MANGA_SAMPLE_DATA.map(d => ({...d})), filename: 'sample_manga.xlsx' };
    setMangaDzState('success', 'sample_manga.xlsx', `${MANGA_SAMPLE_DATA.length} manga sample dimuat`);
    populateMangaSelects(headers);
    const modal = document.getElementById('manga-mapping-modal');
    if (modal) modal.style.display = 'flex';
  }

  // Show genre winner banner if coming from genre module
  window.initMangaUploadFromGenre = function() {
    const winner = sessionStorage.getItem('spk_genreWinner');
    if (winner) {
      const banner = document.getElementById('manga-genre-banner');
      const label  = document.getElementById('manga-genre-winner-label');
      if (banner) banner.classList.remove('hidden');
      if (label)  label.textContent = winner;
    }
  };

  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('manga-upload-back')?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('spk:back-to-hero'));
    });

    const dz    = document.getElementById('manga-dropzone');
    const input = document.getElementById('manga-file-input');

    ['dragenter','dragover'].forEach(evt => {
      dz?.addEventListener(evt, (e) => { e.preventDefault(); dz.style.borderColor='#10b981'; dz.style.background='#d1fae5'; });
    });
    ['dragleave','dragend'].forEach(evt => {
      dz?.addEventListener(evt, () => { dz.style.borderColor='var(--ink)'; dz.style.background='#e5e5e5'; });
    });
    dz?.addEventListener('drop', (e) => {
      e.preventDefault(); dz.style.borderColor='var(--ink)'; dz.style.background='#e5e5e5';
      const file = e.dataTransfer?.files[0];
      if (file) handleMangaFile(file);
    });
    input?.addEventListener('change', (e) => {
      const file = e.target.files?.[0];
      if (file) handleMangaFile(file);
    });

    document.getElementById('manga-use-sample')?.addEventListener('click', loadMangaSampleData);

    document.getElementById('manga-map-close')?.addEventListener('click', () => {
      const modal = document.getElementById('manga-mapping-modal');
      if (modal) modal.style.display = 'none';
      setMangaDzState('idle'); // Reset dropzone state so user can upload again
    });

    document.getElementById('manga-map-confirm')?.addEventListener('click', () => {
      const vals = {};
      const errors = [];
      MANGA_MAP_IDS.forEach((id, i) => {
        const sel = document.getElementById(id);
        const v = sel?.value || '';
        vals[MANGA_MAP_KEYS[i]] = v;
        if (!v) errors.push(`Kolom ${MANGA_MAP_KEYS[i].toUpperCase()} wajib dipilih.`);
      });

      const errEl   = document.getElementById('manga-map-error');
      const errText = document.getElementById('manga-map-error-text');
      if (errors.length) {
        errEl?.classList.remove('hidden');
        if (errText) errText.textContent = errors[0];
        return;
      }
      errEl?.classList.add('hidden');

      if (!mangaRawData) return;

      // Build matrix
      const names = [];
      const matrixX = [];
      const criteriaKeys = ['c1','c2','c3','c4','c5','c6'];

      mangaRawData.rows.forEach(row => {
        const n = String(row[vals.name] || '').trim();
        if (!n) return;
        names.push(n);
        matrixX.push(criteriaKeys.map(k => {
          const raw = row[vals[k]];
          const parsed = parseFloat(String(raw).replace(/,/g, '.'));
          return isNaN(parsed) ? 0 : parsed;
        }));
      });

      if (names.length < 2) {
        alert('Minimal 2 manga diperlukan untuk perbandingan.'); return;
      }

      sessionStorage.setItem('spk_mangaNames',   JSON.stringify(names));
      sessionStorage.setItem('spk_mangaMatrixX',  JSON.stringify(matrixX));
      sessionStorage.setItem('spk_mangaMapping',  JSON.stringify(vals));

      const modal = document.getElementById('manga-mapping-modal');
      if (modal) modal.style.display = 'none';

      window.dispatchEvent(new CustomEvent('spk:manga-goto-step', { detail: { step: 2 } }));
    });

    // Check if coming from genre module
    const winner = sessionStorage.getItem('spk_genreWinner');
    if (winner) {
      const banner = document.getElementById('manga-genre-banner');
      const label  = document.getElementById('manga-genre-winner-label');
      if (banner) banner.classList.remove('hidden');
      if (label)  label.textContent = winner;
    }
  });
</script>

