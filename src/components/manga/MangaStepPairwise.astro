---
// src/components/manga/MangaStepPairwise.astro
---

<section id="manga-step-pairwise" class="pt-20 pb-12 bg-transparent" style="display:none;">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="mb-8 anim-slide-up flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 flex items-center justify-center border-[3px] border-slate-900 shadow-[4px_4px_0px_rgba(15,23,42,1)] transform -rotate-3" style="background:#10b981;">
          <span class="font-black text-2xl text-white" style="font-family:'Rajdhani',sans-serif;">2</span>
        </div>
        <div>
          <h2 class="text-3xl font-black text-white uppercase tracking-wide" style="font-family:'Rajdhani',sans-serif;">Bobot Kriteria Manga</h2>
          <p class="text-slate-600 font-bold bg-white inline-block px-2 py-0.5 border-2 border-slate-900 shadow-[2px_2px_0px_rgba(15,23,42,1)] mt-1">Perbandingan berpasangan 6 kriteria (AHP)</p>
        </div>
      </div>
      <button id="manga-pairwise-back" class="btn-secondary flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12"/>
        </svg>
        Kembali
      </button>
    </div>

    <!-- Criteria Info Banner -->
    <div class="mb-6 brutal-card p-4 bg-slate-900 text-white">
      <div class="flex flex-wrap gap-2 text-xs font-bold">
        <span class="text-slate-400 uppercase tracking-widest mr-2">Kriteria:</span>
        <span class="px-2 py-1 border border-emerald-500 text-emerald-300">C1 Skor</span>
        <span class="px-2 py-1 border border-emerald-500 text-emerald-300">C2 Members</span>
        <span class="px-2 py-1 border border-emerald-500 text-emerald-300">C3 Favorites</span>
        <span class="px-2 py-1 border border-emerald-500 text-emerald-300">C4 Chapter</span>
        <span class="px-2 py-1 border border-emerald-500 text-emerald-300">C5 Tahun</span>
        <span class="px-2 py-1 border border-red-500 text-red-300">C6 Rank (Cost)</span>
        <span class="text-slate-400 ml-4">| Skala Saaty 1–9</span>
      </div>
    </div>

    <!-- Grid: Table + Sidebar -->
    <div class="grid lg:grid-cols-3 gap-6">

      <!-- Pairwise Table -->
      <div class="lg:col-span-2">
        <div class="brutal-card overflow-hidden bg-white">
          <div class="overflow-x-auto">
            <table id="manga-pairwise-table" class="w-full text-sm font-bold" style="font-family:'Rajdhani',sans-serif; min-width:540px;">
              <!-- Generated by JS -->
            </table>
          </div>
          <div class="px-4 py-3 border-t-[3px] border-slate-900 bg-slate-100 text-xs font-bold text-slate-600 uppercase tracking-widest">
            Nilai bawah disi otomatis sebagai resiprokal
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-5">

        <!-- CR Box -->
        <div class="brutal-card p-4" id="manga-cr-box">
          <h3 class="font-black text-slate-900 uppercase tracking-widest text-xs mb-3 border-b-2 border-slate-900 pb-2">Consistency Ratio (CR)</h3>
          <div class="text-center">
            <div id="manga-cr-value" class="text-4xl font-black mb-1" style="font-family:'Rajdhani',sans-serif; color:#6b7280;">—</div>
            <div id="manga-cr-status" class="text-xs font-bold uppercase tracking-widest text-slate-500">Isi matriks dulu</div>
          </div>
          <div class="mt-3 text-xs text-slate-500 font-bold border-t border-slate-200 pt-2">
            CR ≤ 0.10 = konsisten ✓
          </div>
        </div>

        <!-- Weight Preview -->
        <div class="brutal-card p-4">
          <h3 class="font-black text-slate-900 uppercase tracking-widest text-xs mb-3 border-b-2 border-slate-900 pb-2">⚡ Bobot Kriteria</h3>
          <div id="manga-weight-preview" class="space-y-2">
            <p class="text-slate-400 text-xs font-bold">Isi tabel untuk melihat bobot...</p>
          </div>
        </div>

        <!-- Next -->
        <button id="manga-pairwise-next"
          style="width:100%; padding:14px; background:#10b981; color:white; border:var(--border-thick); font-weight:800; font-size:0.95rem; text-transform:uppercase; letter-spacing:0.05em; box-shadow:var(--shadow-offset); cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px; transition:all 0.1s;"
          onmouseover="this.style.transform='translate(-2px,-2px)'; this.style.boxShadow='6px 6px 0px var(--ink)'"
          onmouseout="this.style.transform='translate(0,0)'; this.style.boxShadow='4px 4px 0px var(--ink)'">
          Hitung Ranking Manga
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  // =============================================
  // Manga Pairwise — AHP for 6 Criteria
  // =============================================

  const MANGA_CRITERIA = [
    { key: 'c1', label: 'C1 Skor',    color: 'emerald' },
    { key: 'c2', label: 'C2 Members', color: 'emerald' },
    { key: 'c3', label: 'C3 Fav',     color: 'emerald' },
    { key: 'c4', label: 'C4 Chapter', color: 'emerald' },
    { key: 'c5', label: 'C5 Tahun',   color: 'emerald' },
    { key: 'c6', label: 'C6 Rank',    color: 'red' },
  ];

  const SAATY_OPTS_M = [
    { v: 9,   l: '9 — Mutlak lebih penting' },
    { v: 8,   l: '8' },
    { v: 7,   l: '7 — Sangat lebih penting' },
    { v: 6,   l: '6' },
    { v: 5,   l: '5 — Lebih penting' },
    { v: 4,   l: '4' },
    { v: 3,   l: '3 — Sedikit lebih penting' },
    { v: 2,   l: '2' },
    { v: 1,   l: '1 — Sama pentingnya' },
    { v: 1/2, l: '1/2' },
    { v: 1/3, l: '1/3 — Sedikit kurang penting' },
    { v: 1/4, l: '1/4' },
    { v: 1/5, l: '1/5 — Kurang penting' },
    { v: 1/6, l: '1/6' },
    { v: 1/7, l: '1/7 — Sangat kurang penting' },
    { v: 1/8, l: '1/8' },
    { v: 1/9, l: '1/9 — Mutlak kurang penting' },
  ];

  const n = 6;
  let mangaCriteriaMatrix = Array.from({ length: n }, () =>
    Array.from({ length: n }, () => 1)
  );

  function formatSaatyM(val) {
    if (!val) return '1';
    if (val >= 1) return Math.round(val).toString();
    return `1/${Math.round(1/val)}`;
  }

  function buildMangaPairwiseTable() {
    const table = document.getElementById('manga-pairwise-table');
    if (!table) return;

    let html = `<thead><tr class="bg-slate-900 text-white uppercase tracking-wider text-xs border-b-[3px] border-slate-900">
      <th class="px-4 py-3 text-left sticky left-0 bg-slate-900 z-10 min-w-[90px] border-r border-slate-700">Kriteria</th>
      ${MANGA_CRITERIA.map(c => {
        const bg = c.color === 'red' ? 'bg-red-950 border-r border-red-900' : 'border-r border-slate-700';
        const textColor = c.color === 'red' ? 'text-red-300' : 'text-emerald-300';
        return `<th class="px-3 py-3 text-center min-w-[108px] ${bg} ${textColor}">${c.label}</th>`;
      }).join('')}
    </tr></thead>`;

    html += '<tbody class="divide-y-[2px] divide-slate-300">';
    for (let i = 0; i < n; i++) {
      const cI = MANGA_CRITERIA[i];
      const isRedRow = cI.color === 'red';
      html += `<tr class="${isRedRow ? 'hover:bg-red-50' : 'hover:bg-emerald-50'} transition-colors">
        <td class="px-4 py-2 font-black sticky left-0 ${isRedRow ? 'bg-red-50 text-red-700' : 'bg-white text-slate-900'} border-r-[2px] border-slate-300 text-xs z-10 whitespace-nowrap">${cI.label}</td>`;
      for (let j = 0; j < n; j++) {
        const cJ = MANGA_CRITERIA[j];
        const isRedCol = cJ.color === 'red';
        if (i === j) {
          html += `<td class="px-3 py-2 text-center ${isRedCol ? 'bg-red-50' : 'bg-emerald-50'} border-r border-slate-200">
            <span class="font-black ${isRedCol ? 'text-red-600' : 'text-emerald-700'} text-base">1</span>
          </td>`;
        } else if (i < j) {
          const cellBg = isRedCol || isRedRow ? 'bg-red-50/30' : 'bg-blue-50';
          html += `<td class="px-2 py-1.5 text-center border-r border-slate-200 ${cellBg}">
            <select data-row="${i}" data-col="${j}" class="manga-pw-select border-2 border-slate-900 px-1 py-1 text-xs font-bold bg-white focus:outline-none w-full" style="min-width:100px;">
              ${SAATY_OPTS_M.map(o => `<option value="${o.v}" ${Math.abs(o.v - 1) < 0.001 ? 'selected' : ''}>${o.l}</option>`).join('')}
            </select>
          </td>`;
        } else {
          html += `<td class="px-3 py-2 text-center border-r border-slate-200 bg-slate-50" id="manga-cell-${i}-${j}">
            <span class="font-bold text-slate-500 text-sm">1</span>
          </td>`;
        }
      }
      html += '</tr>';
    }
    html += '</tbody>';
    table.innerHTML = html;

    table.querySelectorAll('.manga-pw-select').forEach(sel => {
      sel.addEventListener('change', () => {
        const r = parseInt(sel.dataset.row);
        const c = parseInt(sel.dataset.col);
        const val = parseFloat(sel.value);
        mangaCriteriaMatrix[r][c] = val;
        mangaCriteriaMatrix[c][r] = val !== 0 ? 1 / val : 1;
        const rc = document.getElementById(`manga-cell-${c}-${r}`);
        if (rc) rc.innerHTML = `<span class="font-bold text-slate-500 text-sm">${formatSaatyM(1/val)}</span>`;
        recalcMangaAHP();
      });
    });

    recalcMangaAHP();
  }

  function recalcMangaAHP() {
    for (let i = 0; i < n; i++) mangaCriteriaMatrix[i][i] = 1;

    const colSums = Array.from({ length: n }, (_, j) =>
      mangaCriteriaMatrix.reduce((sum, row) => sum + row[j], 0)
    );
    const norm = mangaCriteriaMatrix.map(row =>
      row.map((v, j) => colSums[j] === 0 ? 0 : v / colSums[j])
    );
    const weights = norm.map(row => row.reduce((s, v) => s + v, 0) / n);

    let lambdaMax = 0;
    for (let j = 0; j < n; j++) lambdaMax += colSums[j] * weights[j];

    const RI = [0, 0, 0.58, 0.90, 1.12, 1.24, 1.32, 1.41, 1.45, 1.49];
    const ci = (lambdaMax - n) / (n - 1);
    const cr = ci / RI[n - 1];
    const isOk = cr <= 0.1;

    const crBox  = document.getElementById('manga-cr-box');
    const crVal  = document.getElementById('manga-cr-value');
    const crStat = document.getElementById('manga-cr-status');
    if (crVal) crVal.textContent = cr.toFixed(4);
    if (crStat) {
      crStat.textContent = isOk ? '✓ Konsisten' : '✗ Perlu Direvisi';
      crStat.style.color = isOk ? '#16a34a' : '#ef4444';
      crVal.style.color  = isOk ? '#16a34a' : '#ef4444';
      if (crBox) crBox.style.background = isOk ? '#dcfce7' : '#fee2e2';
    }

    const preview = document.getElementById('manga-weight-preview');
    if (preview) {
      const items = MANGA_CRITERIA.map((c, i) => ({ label: c.label, w: weights[i], color: c.color }))
        .sort((a, b) => b.w - a.w);
      preview.innerHTML = items.map((item, idx) => `
        <div class="flex items-center gap-2">
          <span class="text-xs font-black text-slate-500 w-4">#${idx+1}</span>
          <div class="flex-1">
            <div class="flex justify-between text-xs mb-0.5">
              <span class="font-black ${item.color === 'red' ? 'text-red-700' : 'text-slate-900'}">${item.label}</span>
              <span class="font-black text-emerald-700">${(item.w * 100).toFixed(1)}%</span>
            </div>
            <div class="w-full bg-slate-200 border border-slate-300" style="height:6px;">
              <div style="height:100%; width:${(item.w * 100).toFixed(1)}%; background:${item.color === 'red' ? '#ef4444' : '#10b981'};"></div>
            </div>
          </div>
        </div>
      `).join('');
    }

    sessionStorage.setItem('spk_mangaCriteriaMatrix', JSON.stringify(mangaCriteriaMatrix));
    sessionStorage.setItem('spk_mangaCriteriaWeights', JSON.stringify(weights));
    sessionStorage.setItem('spk_mangaCR', cr.toFixed(4));
    sessionStorage.setItem('spk_mangaConsistent', JSON.stringify(isOk));
  }

  window.initMangaPairwise = function() {
    buildMangaPairwiseTable();
  };

  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('manga-pairwise-back')?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('spk:manga-goto-step', { detail: { step: 1 } }));
    });

    document.getElementById('manga-pairwise-next')?.addEventListener('click', () => {
      // Check all upper triangle filled (non-zero)
      let allFilled = true;
      for (let i = 0; i < n && allFilled; i++) {
        for (let j = i+1; j < n && allFilled; j++) {
          if (!mangaCriteriaMatrix[i][j]) allFilled = false;
        }
      }
      if (!allFilled) { alert('Harap isi semua sel perbandingan kriteria.'); return; }
      window.dispatchEvent(new CustomEvent('spk:manga-goto-step', { detail: { step: 3 } }));
    });
  });
</script>
