---
// src/components/StepMatriks.astro
---

<section id="step-matriks" class="pt-20 pb-12 bg-transparent" style="display:none;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="mb-8 anim-slide-up flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 bg-blue-600 text-white flex items-center justify-center border-[3px] border-slate-900 shadow-[4px_4px_0px_rgba(15,23,42,1)] transform -rotate-3">
          <span class="font-black text-2xl" style="font-family:'Rajdhani',sans-serif;">2</span>
        </div>
        <div>
          <h2 class="text-3xl font-black text-white uppercase tracking-wide" style="font-family:'Rajdhani',sans-serif;">Matriks Keputusan (X)</h2>
          <p class="text-slate-600 font-bold bg-white inline-block px-2 py-0.5 border-2 border-slate-900 shadow-[2px_2px_0px_rgba(15,23,42,1)] mt-1">Klik sel untuk mengedit nilai</p>
        </div>
      </div>
      <div class="flex flex-wrap gap-3">
        <button id="btn-reset-matrix" class="flex items-center gap-1.5 px-4 py-2 bg-white text-slate-900 font-bold text-sm uppercase tracking-wide border-[3px] border-slate-900 shadow-[4px_4px_0px_rgba(15,23,42,1)] transition-transform hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[6px_6px_0px_rgba(15,23,42,1)] active:translate-x-1 active:translate-y-1 active:shadow-[0px_0px_0px_rgba(15,23,42,1)]">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          Reset Data
        </button>
        <button id="btn-matriks-back" class="btn-secondary flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
          </svg>
          Kembali
        </button>
        <button id="btn-matriks-next" class="btn-primary flex items-center gap-1.5">
          <span>Hitung SAW</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l5-5m5-5H6" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Legend -->
    <div class="mb-4 flex flex-wrap gap-4 text-xs font-bold uppercase tracking-widest">
      <div class="flex items-center gap-2 px-3 py-1.5 bg-white border-2 border-slate-900 shadow-[2px_2px_0px_rgba(15,23,42,1)]">
        <div class="w-3 h-3 bg-blue-600 border border-slate-900"></div>
        <span class="text-blue-700">Benefit (Max)</span>
      </div>
      <div class="flex items-center gap-2 px-3 py-1.5 bg-white border-2 border-slate-900 shadow-[2px_2px_0px_rgba(15,23,42,1)]">
        <div class="w-3 h-3 bg-red-500 border border-slate-900"></div>
        <span class="text-red-700">Cost (Min)</span>
      </div>
    </div>

    <!-- Table container -->
    <div class="brutal-card overflow-hidden bg-white">
      <div class="overflow-x-auto">
        <table class="w-full text-sm font-bold" id="matrix-table" style="font-family: 'Rajdhani', sans-serif;">
          <thead>
            <tr class="bg-slate-900 text-white uppercase tracking-wider text-sm border-b-[3px] border-slate-900">
              <th class="sticky left-0 bg-slate-900 px-4 py-3 text-left z-10 whitespace-nowrap min-w-[180px] border-r-2 border-slate-700">
                Studio
              </th>
              <th class="px-3 py-3 text-center whitespace-nowrap min-w-[100px] border-r border-slate-700">
                <div class="text-base text-blue-400">C1</div>
                <div class="text-[0.7rem] text-slate-300">Skor MAL</div>
              </th>
              <th class="px-3 py-3 text-center whitespace-nowrap min-w-[100px] border-r border-slate-700">
                <div class="text-base text-blue-400">C2</div>
                <div class="text-[0.7rem] text-slate-300">Members</div>
              </th>
              <th class="px-3 py-3 text-center whitespace-nowrap min-w-[100px] border-r border-slate-700">
                <div class="text-base text-blue-400">C3</div>
                <div class="text-[0.7rem] text-slate-300">Produktivitas</div>
              </th>
              <th class="px-3 py-3 text-center whitespace-nowrap min-w-[100px] bg-red-950 border-r border-red-900">
                <div class="text-base text-red-400">C4 🔥</div>
                <div class="text-[0.7rem] text-red-200">Rasio Flop</div>
              </th>
              <th class="px-3 py-3 text-center whitespace-nowrap min-w-[100px] border-r border-slate-700">
                <div class="text-base text-blue-400">C5</div>
                <div class="text-[0.7rem] text-slate-300">Favorites</div>
              </th>
              <th class="px-3 py-3 text-center whitespace-nowrap min-w-[100px]">
                <div class="text-base text-blue-400">C6</div>
                <div class="text-[0.7rem] text-slate-300">Masterpiece</div>
              </th>
            </tr>
          </thead>
          <tbody id="matrix-tbody" class="divide-y-[2px] divide-slate-300">
            <!-- Rows injected by JS -->
            <tr>
              <td colspan="7" class="px-4 py-12 text-center text-slate-500">
                <div class="flex flex-col items-center gap-3">
                  <div class="w-12 h-12 border-[4px] border-slate-200 border-t-slate-900 animate-spin"></div>
                  <span class="text-base font-black uppercase tracking-widest">Memuat data...</span>
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Table footer: studio count -->
      <div class="px-4 py-3 bg-slate-100 border-t-[3px] border-slate-900 flex items-center justify-between text-xs font-bold text-slate-600 uppercase">
        <span id="matrix-count">0 studio dimuat</span>
        <span>Perubahan tersimpan otomatis</span>
      </div>
    </div>

  </div>
</section>

<script>
  let originalData = null; // backup untuk reset

  window.initMatriksStep = function() {
    // Load data dari sessionStorage
    const studiosRaw = sessionStorage.getItem('spk_studioNames');
    const matrixRaw = sessionStorage.getItem('spk_matrixX');

    if (!studiosRaw || !matrixRaw) {
      console.warn('[SPK] No matrix data in sessionStorage');
      return;
    }

    const studios = JSON.parse(studiosRaw);
    const matrixX = JSON.parse(matrixRaw);

    originalData = { studios: JSON.parse(studiosRaw), matrixX: JSON.parse(matrixRaw) };

    renderMatrixTable(studios, matrixX);
  };

  function renderMatrixTable(studios, matrixX) {
    const tbody = document.getElementById('matrix-tbody');
    const countEl = document.getElementById('matrix-count');
    if (!tbody) return;

    tbody.innerHTML = '';

    studios.forEach((studio, i) => {
      const row = document.createElement('tr');
      row.className = 'hover:bg-blue-50 transition-colors group';
      row.dataset.index = i;

      // Studio name cell
      const tdName = document.createElement('td');
      tdName.className = 'sticky left-0 px-4 py-2 text-slate-900 whitespace-nowrap bg-white group-hover:bg-blue-50 z-10 border-r-[2px] border-slate-300 text-sm font-black';
      tdName.textContent = studio;
      row.appendChild(tdName);

      // Criteria cells
      const criteriaKeys = ['c1', 'c2', 'c3', 'c4', 'c5', 'c6'];
      criteriaKeys.forEach((key, j) => {
        const td = document.createElement('td');
        td.className = 'px-2 py-1.5 text-center border-r border-slate-200';
        if (key === 'c4') td.className += ' bg-red-50 group-hover:bg-red-100';

        const input = document.createElement('input');
        input.type = 'number';
        input.className = 'table-cell-input text-base text-slate-900 focus:shadow-[3px_3px_0px_#2563eb]' + (key === 'c4' ? ' !text-red-700 bg-red-50 focus:shadow-[3px_3px_0px_#ef4444]' : '');
        input.value = matrixX[i]?.[j] ?? 0;
        input.step = key === 'c1' ? '0.01' : key === 'c4' ? '0.1' : '1';
        input.min = '0';
        input.dataset.row = i;
        input.dataset.col = j;

        input.addEventListener('change', () => {
          saveMatrixChanges();
        });

        td.appendChild(input);
        row.appendChild(td);
      });

      tbody.appendChild(row);
    });

    if (countEl) countEl.textContent = `${studios.length} studio dimuat`;
  }

  function saveMatrixChanges() {
    const inputs = document.querySelectorAll('#matrix-tbody input[data-row]');
    const studiosRaw = sessionStorage.getItem('spk_studioNames');
    if (!studiosRaw) return;
    const studios = JSON.parse(studiosRaw);
    const newMatrix = Array.from({ length: studios.length }, () => []);

    inputs.forEach(input => {
      const row = parseInt(input.dataset.row);
      const col = parseInt(input.dataset.col);
      newMatrix[row][col] = parseFloat(input.value) || 0;
    });

    sessionStorage.setItem('spk_matrixX', JSON.stringify(newMatrix));
  }

  // Reset to original
  document.getElementById('btn-reset-matrix')?.addEventListener('click', () => {
    if (!originalData) return;
    if (!confirm('Reset ke data original?')) return;

    sessionStorage.setItem('spk_studioNames', JSON.stringify(originalData.studios));
    sessionStorage.setItem('spk_matrixX', JSON.stringify(originalData.matrixX));
    renderMatrixTable(originalData.studios, originalData.matrixX);
  });

  // Navigation
  document.getElementById('btn-matriks-back')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('spk:goto-step', { detail: { step: 1 } }));
  });

  document.getElementById('btn-matriks-next')?.addEventListener('click', () => {
    saveMatrixChanges(); // ensure saved
    window.dispatchEvent(new CustomEvent('spk:goto-step', { detail: { step: 3 } }));
  });
</script>
