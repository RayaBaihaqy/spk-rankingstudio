---
// src/components/genre/genreStepHasil.astro
---

<section id="genre-step-hasil" class="pt-20 pb-12 bg-transparent" style="display:none;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="mb-8 anim-slide-up flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 flex items-center justify-center border-[3px] border-slate-900 shadow-[4px_4px_0px_rgba(15,23,42,1)] transform -rotate-3" style="background:#10b981;">
          <span class="font-black text-2xl text-white" style="font-family:'Rajdhani',sans-serif;">3</span>
        </div>
        <div>
          <h2 class="text-3xl font-black text-white uppercase tracking-wide" style="font-family:'Rajdhani',sans-serif;">Hasil Ranking genre</h2>
          <p class="text-slate-600 font-bold bg-white inline-block px-2 py-0.5 border-2 border-slate-900 shadow-[2px_2px_0px_rgba(15,23,42,1)] mt-1">Normalisasi SAW dengan bobot AHP</p>
        </div>
      </div>
      <div class="flex flex-wrap gap-3">
        <button id="genre-hasil-back" class="btn-secondary flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12"/>
          </svg>
          Kembali
        </button>
        <button id="genre-export-excel" class="btn-primary flex items-center gap-1.5" style="background:#10b981;">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          Export Excel
        </button>
      </div>
    </div>

    <!-- Loading -->
    <div id="genre-hasil-loading" class="text-center py-16">
      <div class="w-16 h-16 mx-auto border-[4px] border-slate-200 border-t-emerald-400 rounded-full mb-4" style="animation:spin-mh 1s linear infinite;"></div>
      <p class="text-white font-black uppercase tracking-widest text-lg" style="font-family:'Rajdhani',sans-serif;">Menghitung...</p>
    </div>

    <!-- Results Content -->
    <div id="genre-hasil-content" class="hidden">

      <!-- CR Banner -->
      <div id="genre-cr-banner" class="mb-6 p-4 border-[3px] border-slate-900 shadow-[4px_4px_0px_rgba(15,23,42,1)] flex items-center gap-4">
        <div id="genre-cr-icon" class="w-12 h-12 flex items-center justify-center font-black text-xl border-2 border-slate-900 flex-shrink-0"></div>
        <div>
          <p class="font-black text-slate-900 uppercase tracking-wider text-sm" id="genre-cr-title-res"></p>
          <p class="font-bold text-sm" id="genre-cr-detail-res"></p>
        </div>
      </div>

      <!-- Weight Summary -->
      <div class="mb-6 brutal-card p-4">
        <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest mb-3 border-b-2 border-slate-900 pb-2">Bobot AHP yang Digunakan:</h3>
        <div class="flex flex-wrap gap-2" id="genre-weight-summary"></div>
      </div>

      <!-- TOP 3 Podium -->
      <div class="mb-10">
        <div class="flex justify-center mb-6">
          <h3 class="text-xl font-black text-slate-900 uppercase tracking-widest px-6 py-2 shadow-[4px_4px_0px_rgba(15,23,42,1)] transform -rotate-1 border-[3px] border-slate-900" style="background:#6ee7b7; font-family:'Rajdhani',sans-serif;">
            TOP 3 genre TERBAIK
          </h3>
        </div>
        <div class="flex items-end justify-center gap-4" id="genre-podium-container"></div>
      </div>

      <!-- Tab Switcher -->
      <div class="flex mb-4 bg-slate-900 p-1 w-fit border-2 border-slate-900 shadow-[4px_4px_0px_rgba(15,23,42,1)]">
        <button id="genre-tab-ranking" onclick="switchgenreTab('ranking')"
          class="px-5 py-2 text-sm font-black uppercase tracking-wider transition-all bg-white text-slate-900 border-2 border-slate-900">
          🏅 Ranking (V)
        </button>
        <button id="genre-tab-normalisasi" onclick="switchgenreTab('normalisasi')"
          class="px-5 py-2 text-sm font-black uppercase tracking-wider transition-all text-white hover:bg-slate-800 border-2 border-transparent">
          📐 Normalisasi (R)
        </button>
      </div>

      <!-- Ranking Table -->
      <div id="genre-tab-ranking-panel" class="brutal-card overflow-hidden bg-white">
        <div class="overflow-x-auto">
          <table class="w-full text-sm font-bold" style="font-family:'Rajdhani',sans-serif;">
            <thead>
              <tr class="bg-slate-900 text-white uppercase tracking-wider text-sm border-b-[3px] border-slate-900">
                <th class="px-4 py-3 text-left w-20 border-r border-slate-700">Rank</th>
                <th class="px-4 py-3 text-left min-w-[200px] border-r border-slate-700">genre</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C1 (R)</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C2 (R)</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C3 (R)</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C4 (R)</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C5 (R)</th>
                <th class="px-3 py-3 text-center bg-red-950 border-r border-red-900">C6 (R)</th>
                <th class="px-4 py-3 text-center font-black min-w-[100px] bg-emerald-900 border-l-[3px] border-slate-900">NILAI V</th>
              </tr>
            </thead>
            <tbody id="genre-ranking-tbody" class="divide-y-[2px] divide-slate-300"></tbody>
          </table>
        </div>
      </div>

      <!-- Normalisasi Table -->
      <div id="genre-tab-normalisasi-panel" class="hidden brutal-card overflow-hidden bg-white">
        <div class="overflow-x-auto">
          <table class="w-full text-sm font-bold" style="font-family:'Rajdhani',sans-serif;">
            <thead>
              <tr class="bg-slate-900 text-white uppercase tracking-wider text-sm border-b-[3px] border-slate-900">
                <th class="px-4 py-3 text-left min-w-[200px] border-r border-slate-700">genre</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C1</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C2</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C3</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C4</th>
                <th class="px-3 py-3 text-center border-r border-slate-700">C5</th>
                <th class="px-3 py-3 text-center bg-red-950 border-r border-red-900">C6</th>
              </tr>
            </thead>
            <tbody id="genre-norm-tbody" class="divide-y-[2px] divide-slate-300"></tbody>
          </table>
        </div>
      </div>

      <!-- Legend -->
      <div class="mt-4 flex flex-wrap gap-4 text-xs font-bold uppercase tracking-widest bg-white p-3 border-2 border-slate-900 shadow-[3px_3px_0px_rgba(15,23,42,1)] w-fit">
        <span class="flex items-center gap-2"><span class="inline-block w-4 h-4 bg-yellow-400 border border-slate-900"></span> Rank 1</span>
        <span class="flex items-center gap-2"><span class="inline-block w-4 h-4 bg-slate-300 border border-slate-900"></span> Rank 2</span>
        <span class="flex items-center gap-2"><span class="inline-block w-4 h-4 bg-orange-600 border border-slate-900"></span> Rank 3</span>
        <span class="ml-4 pl-4 border-l-2 border-slate-300 text-slate-500">R = Normalized (0–1) | V = Σ(w × r)</span>
      </div>

      <!-- Actions -->
      <div class="mt-6 flex flex-wrap gap-4">
        <button id="genre-hasil-next" class="btn-primary flex items-center gap-2" style="background:#f59e0b;">
          Lanjut ke Prioritas Manga
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </button>
        <button id="genre-hasil-home" class="btn-secondary flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          Pilih Modul Lain
        </button>
      </div>

    </div>
  </div>
</section>

<script>
  // =============================================
  // genre Hasil — SAW with AHP weights
  // =============================================

  const genre_CRITERIA_TYPES = ['Benefit','Benefit','Benefit','Benefit','Benefit','Cost'];
  const genre_CRITERIA_LABELS = ['C1 Popularitas','C2 Rating','C3 Jml Anime','C4 Tren','C5 R>=7','C6 R<6'];

  window.switchgenreTab = function(tab) {
    const tabR = document.getElementById('genre-tab-ranking-panel');
    const tabN = document.getElementById('genre-tab-normalisasi-panel');
    const btnR = document.getElementById('genre-tab-ranking');
    const btnN = document.getElementById('genre-tab-normalisasi');
    if (tab === 'ranking') {
      tabR?.classList.remove('hidden'); tabN?.classList.add('hidden');
      btnR?.classList.add('bg-white','text-slate-900','border-slate-900');
      btnR?.classList.remove('text-white','hover:bg-slate-800','border-transparent');
      btnN?.classList.add('text-white','hover:bg-slate-800','border-transparent');
      btnN?.classList.remove('bg-white','text-slate-900','border-slate-900');
    } else {
      tabN?.classList.remove('hidden'); tabR?.classList.add('hidden');
      btnN?.classList.add('bg-white','text-slate-900','border-slate-900');
      btnN?.classList.remove('text-white','hover:bg-slate-800','border-transparent');
      btnR?.classList.add('text-white','hover:bg-slate-800','border-transparent');
      btnR?.classList.remove('bg-white','text-slate-900','border-slate-900');
    }
  };

  window.initGenreHasil = function() {
    const loadingEl = document.getElementById('genre-hasil-loading');
    const contentEl = document.getElementById('genre-hasil-content');
    loadingEl?.style.setProperty('display','block');
    contentEl?.classList.add('hidden');
    setTimeout(() => {
      try {
        rungenreSAWAndRender();
        loadingEl?.style.setProperty('display','none');
        contentEl?.classList.remove('hidden');
      } catch(err) {
        loadingEl?.style.setProperty('display','none');
        console.error('[SPK genre]', err);
        alert('Terjadi kesalahan saat menghitung hasil.');
      }
    }, 400);
  };

  function rungenreSAWAndRender() {
    const names   = JSON.parse(sessionStorage.getItem('spk_genreNames')           || '[]');
    const matrixX = JSON.parse(sessionStorage.getItem('spk_genreMatrixX')          || '[]');
    const weights = JSON.parse(sessionStorage.getItem('spk_genreCriteriaWeights')  || '[]');
    const crStr   = sessionStorage.getItem('spk_genreCR')                           || '0';
    const isOk    = sessionStorage.getItem('spk_genreConsistent') === 'true';
    const cr      = parseFloat(crStr);

    if (!names.length || !matrixX.length || !weights.length) {
      alert('Data tidak lengkap. Silakan ulangi dari langkah 1.');
      return;
    }

    const m = 6;
    // Normalisasi SAW
    const maxCol = Array.from({ length: m }, (_, j) => Math.max(...matrixX.map(r => r[j])));
    const minCol = Array.from({ length: m }, (_, j) => Math.min(...matrixX.map(r => r[j])));

    const matrixR = matrixX.map(row => row.map((val, j) => {
      if (genre_CRITERIA_TYPES[j] === 'Benefit') {
        // C4 (index 3) memiliki nilai negatif → pakai min-max normalization
        // Kriteria benefit lain → pakai standard SAW: val / max
        if (j === 3) {
          const denom = maxCol[j] - minCol[j];
          return denom === 0 ? 0 : (val - minCol[j]) / denom;
        } else {
          return maxCol[j] === 0 ? 0 : val / maxCol[j];
        }
      } else {
        // Cost (C6): (max - val) / (max - min)
        // Rumus ini cocok dengan PDF dan aman saat min = 0
        const denom = maxCol[j] - minCol[j];
        return denom === 0 ? 0 : (maxCol[j] - val) / denom;
      }
    }));

    const valuesV = matrixR.map(row => row.reduce((sum, rij, j) => sum + rij * weights[j], 0));

    const ranked = names.map((name, i) => ({ name, v: valuesV[i], r: matrixR[i], x: matrixX[i] }))
      .sort((a, b) => b.v - a.v)
      .map((item, idx) => ({ ...item, rank: idx + 1 }));

    sessionStorage.setItem('spk_genreResults', JSON.stringify(ranked));

    // CR Banner
    const banner = document.getElementById('genre-cr-banner');
    const icon   = document.getElementById('genre-cr-icon');
    const title  = document.getElementById('genre-cr-title-res');
    const detail = document.getElementById('genre-cr-detail-res');
    if (banner && icon && title && detail) {
      banner.style.background = isOk ? '#dcfce7' : '#fee2e2';
      icon.style.background   = isOk ? '#22c55e' : '#ef4444';
      icon.style.color        = 'white';
      icon.textContent        = isOk ? '✓' : '!';
      title.textContent       = isOk ? 'Bobot Kriteria Konsisten' : 'Bobot Kriteria Tidak Konsisten';
      detail.style.color      = isOk ? '#16a34a' : '#ef4444';
      detail.textContent      = `CR = ${cr.toFixed(4)} ${isOk ? '≤ 0.10 — Hasil dapat dipercaya' : '> 0.10 — Pertimbangkan merevisi perbandingan'}`;
    }

    // Weight Summary
    const wSummary = document.getElementById('genre-weight-summary');
    if (wSummary) {
      wSummary.innerHTML = genre_CRITERIA_LABELS.map((lbl, i) => {
        const isC6 = i === 5;
        return `<span class="px-3 py-1.5 text-xs font-black uppercase tracking-wider border-2 border-slate-900 shadow-[2px_2px_0px_rgba(15,23,42,1)] ${isC6 ? 'bg-red-50 text-red-700' : 'bg-emerald-50 text-emerald-700'}">
          ${lbl}: <span class="text-slate-900">${(weights[i] || 0).toFixed(4)}</span>
        </span>`;
      }).join('');
    }

    // Podium
    rendergenrePodium(ranked);
    rendergenreRankingTable(ranked);
    rendergenreNormTable(names, matrixR);
  }

  function rendergenrePodium(ranked) {
    const container = document.getElementById('genre-podium-container');
    if (!container) return;
    const MEDALS  = { 1: '🥇', 2: '🥈', 3: '🥉' };
    const HEIGHTS = { 1: '140px', 2: '100px', 3: '80px' };
    const COLORS  = { 1: '#facc15', 2: '#cbd5e1', 3: '#ea580c' };
    const ORDER   = [2, 1, 3];
    container.innerHTML = ORDER.map(rank => {
      const item = ranked.find(r => r.rank === rank);
      if (!item) return '';
      return `<div class="flex flex-col items-center gap-2 anim-slide-up" style="animation-delay:${(rank-1)*0.15}s; z-index:${4-rank};">
        <div class="text-4xl filter drop-shadow-md">${MEDALS[rank]}</div>
        <div class="text-center bg-white border-2 border-slate-900 px-3 py-1 shadow-[3px_3px_0px_rgba(15,23,42,1)] -mb-2 z-10">
          <p class="font-black text-slate-900 text-sm uppercase" style="font-family:'Rajdhani',sans-serif; max-width:140px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${item.name}</p>
          <p class="text-xs font-bold text-slate-600">V = <strong class="text-emerald-700">${item.v.toFixed(4)}</strong></p>
        </div>
        <div class="w-24 sm:w-32 flex items-center justify-center font-black text-slate-900 text-4xl border-[3px] border-slate-900 border-b-0"
          style="height:${HEIGHTS[rank]}; background:${COLORS[rank]}; box-shadow:6px 0px 0px var(--ink);">
          ${rank}
        </div>
      </div>`;
    }).join('');
  }

  function rendergenreRankingTable(ranked) {
    const tbody = document.getElementById('genre-ranking-tbody');
    if (!tbody) return;
    tbody.innerHTML = ranked.map(item => {
      const rowBg = item.rank === 1 ? 'bg-yellow-100 hover:bg-yellow-200'
                  : item.rank === 2 ? 'bg-slate-100 hover:bg-slate-200'
                  : item.rank === 3 ? 'bg-orange-100 hover:bg-orange-200'
                  : 'bg-white hover:bg-emerald-50';
      const badge = item.rank <= 3
        ? `<span class="rank-badge-${item.rank} inline-block">${['🥇','🥈','🥉'][item.rank-1]} #${item.rank}</span>`
        : `<span class="text-slate-500 font-black">#${item.rank}</span>`;
      return `<tr class="${rowBg} transition-colors group">
        <td class="px-4 py-3 border-r border-slate-300">${badge}</td>
        <td class="px-4 py-3 font-black text-slate-900 text-base border-r border-slate-300 uppercase">${item.name}</td>
        ${item.r.map((v, j) => `
          <td class="px-3 py-3 text-center text-slate-700 border-r border-slate-300 ${j === 5 ? 'bg-red-50/50 text-red-700 group-hover:bg-red-100' : ''}">${v.toFixed(4)}</td>
        `).join('')}
        <td class="px-4 py-3 text-center bg-emerald-50 border-l-[3px] border-slate-900 group-hover:bg-emerald-100 transition-colors">
          <span class="font-black text-emerald-700 text-xl" style="font-family:'Rajdhani',sans-serif;">${item.v.toFixed(4)}</span>
        </td>
      </tr>`;
    }).join('');
  }

  function rendergenreNormTable(names, matrixR) {
    const tbody = document.getElementById('genre-norm-tbody');
    if (!tbody) return;
    tbody.innerHTML = names.map((name, i) => `
      <tr class="${i % 2 === 0 ? 'bg-white' : 'bg-slate-50'} hover:bg-emerald-50 transition-colors group">
        <td class="px-4 py-3 font-black text-slate-900 text-base border-r border-slate-300 uppercase">${name}</td>
        ${(matrixR[i] || []).map((v, j) => `
          <td class="px-3 py-3 text-center text-slate-700 border-r border-slate-300 ${j === 5 ? 'bg-red-50/50 text-red-700 group-hover:bg-red-100' : ''}">${v.toFixed(4)}</td>
        `).join('')}
      </tr>
    `).join('');
  }

  // Export Excel
  document.getElementById('genre-export-excel')?.addEventListener('click', () => {
    const ranked = JSON.parse(sessionStorage.getItem('spk_genreResults') || '[]');
    if (!ranked.length) { alert('Belum ada data hasil.'); return; }
    if (typeof XLSX === 'undefined') { alert('Library Excel belum dimuat.'); return; }

    const headers = ['Rank','genre','C1 (R)','C2 (R)','C3 (R)','C4 (R)','C5 (R)','C6 (R)','Nilai V'];
    const rows = ranked.map(item => [
      item.rank, item.name,
      ...item.r.map(v => parseFloat(v.toFixed(4))),
      parseFloat(item.v.toFixed(4))
    ]);

    const ws = XLSX.utils.aoa_to_sheet([headers, ...rows]);
    ws['!cols'] = [{ wch: 6 }, { wch: 28 }, ...Array(6).fill({ wch: 10 }), { wch: 10 }];
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'Hasil genre');
    XLSX.writeFile(wb, 'Hasil_SPK_Prioritas_genre.xlsx');
  });

  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('genre-hasil-back')?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('spk:genre-goto-step', { detail: { step: 2 } }));
    });
    document.getElementById('genre-hasil-home')?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('spk:back-to-hero'));
    });
    document.getElementById('genre-hasil-next')?.addEventListener('click', () => {
      const ranked = JSON.parse(sessionStorage.getItem('spk_genreResults') || '[]');
      if (ranked.length > 0) {
        sessionStorage.setItem('spk_genreWinner', ranked[0].name);
      }
      window.dispatchEvent(new CustomEvent('spk:genre-to-manga'));
    });
  });
</script>

<style>
  @keyframes spin-mh { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
</style>
